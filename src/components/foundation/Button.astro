---
interface Props {
  href?: string;
  variant?: 'primary' | 'quiet';
  class?: string;
}
const { href, variant = 'primary', class: className = '' } = Astro.props;
const Tag = href ? 'a' : 'button';
const base =
  'inline-flex items-center justify-center gap-2 rounded-(--radius-control) px-5 py-2.5 ' +
  'text-small font-medium transition-all duration-200 active:translate-y-px';
const variants = {
  primary:
    'bg-terracotta-500 text-void hover:bg-terracotta-400',
  quiet:
    'border border-line text-ink-hi hover:border-line-hover hover:bg-raised',
};
---

<Tag href={href} class={`${base} ${variants[variant]} ${className}`}>
  <slot />
</Tag>
