---
// Section 1 (04 §2): badge → H1 → CTAs → set-piece → stat strip. No eyebrow, no sub.
// Parallax site #1 of 2 (03 §3.1): glow 0.85× · terminal 1.0× · stat strip 1.04×.
import Badge from '../foundation/Badge.astro';
import Heading from '../foundation/Heading.astro';
import CopyChip from '../foundation/CopyChip.astro';
import StatStrip from '../foundation/StatStrip.astro';
import HorizonGlow from '../foundation/HorizonGlow.astro';
import ForkingTerminal from './hero/ForkingTerminal.tsx';
import release from '../../data/release.json';
import benchmarks from '../../data/benchmarks.json';
---

<section class="relative overflow-hidden">
  <!-- The living backdrop (2026-06-12): three light fields breathing on the
       neutral stage. Transform-only, GPU-composited, 22–36s periods —
       sanctioned infinite animation #2 (03 §5 amendment). -->
  <div class="hero-backdrop pointer-events-none absolute inset-0" aria-hidden="true">
    <div class="hero-light hero-light-ember"></div>
    <div class="hero-light hero-light-cool"></div>
    <div class="hero-light hero-light-deep"></div>
    <!-- The branching river (2026-06-12): the product thesis as artwork — a
         trunk forks, strands diverge, one merges back. Energy flows along the
         lines via dashoffset; each strand = wide glow stroke + bright core. -->
    <svg class="hero-river absolute inset-0 h-full w-full" viewBox="0 0 1440 900" fill="none" preserveAspectRatio="xMidYMid slice">
      {
        [
          { d: 'M -40 430 C 280 430 360 430 520 360 C 700 280 900 250 1480 230', cls: 'river-ember', dur: '7s' },
          { d: 'M -40 430 C 300 430 420 440 560 500 C 760 590 980 620 1480 600', cls: 'river-ember', dur: '9s' },
          { d: 'M -40 430 C 320 432 480 420 640 420 C 880 420 1100 430 1480 425', cls: 'river-cool', dur: '11s' },
          { d: 'M 520 360 C 640 320 760 360 880 420 C 1000 480 1100 430 1180 428', cls: 'river-ember-dim', dur: '8s' },
          { d: 'M -40 470 C 240 470 400 520 540 560 C 720 610 900 560 1480 660', cls: 'river-ember-dim', dur: '13s' },
        ].map((p) => (
          <>
            <path d={p.d} class={`river-glow ${p.cls}`} style={`--dur: ${p.dur}`} />
            <path d={p.d} class={`river-core ${p.cls}`} style={`--dur: ${p.dur}`} />
          </>
        ))
      }
    </svg>
  </div>
  <div data-parallax="0.85" class="absolute inset-0 will-change-transform">
    <HorizonGlow />
  </div>

  <div class="relative mx-auto w-full max-w-[70rem] px-6 pb-24 pt-20 max-[480px]:px-4 md:pt-28">
    <div class="mb-14 text-center">
      <Badge href="/changelog" class="mb-8">Research preview · v{release.version}</Badge>
      <Heading level={1} size="display-xl">Strata is the embedded database with git-like powers</Heading>

      <!-- The acquisition control (2026-06-12): the hero IS the act surface.
           No Get Started — get the product: CLI via curl, or the studio. -->
      <div class="mt-10 inline-flex flex-wrap items-stretch justify-center overflow-hidden rounded-(--radius-control) border border-line bg-panel">
        <CopyChip value="curl -fsSL stratadb.org/install.sh | sh" class="!rounded-none !border-0 !bg-transparent" />
        <span class="w-px self-stretch bg-line max-[560px]:hidden" aria-hidden="true"></span>
        <a
          href="https://github.com/stratalab/strata-foundry"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-2 px-4 py-2.5 font-mono text-mono-sm text-terracotta-400 transition-colors duration-200 hover:bg-raised hover:text-terracotta-300"
        >
          <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v12m0 0l-4.5-4.5M12 15l4.5-4.5M4 20h16"></path>
          </svg>
          Download Foundry
        </a>
      </div>
      <p class="mt-4 font-mono text-mono-sm text-ink-low">
        for your agent → <a href="/llms.txt" class="text-ink-mid transition-colors duration-200 hover:text-ink-hi">stratadb.org/llms.txt</a>
      </p>
    </div>

    <div class="mx-auto max-w-[56rem]">
      <ForkingTerminal client:visible />
    </div>

    <div data-parallax="1.04" class="mt-24 will-change-transform">
      <StatStrip items={benchmarks.stats} />
    </div>
  </div>
</section>

<style>
  /* Perceptibility fix (2026-06-12): the first cut moved ~0.5%/s — technically
     animated, perceptually static. Now: 11–18s periods, wider travel, and
     opacity breathing (the eye catches luminosity change fastest). Still
     transform/opacity only; still off under reduced motion. */
  .hero-light {
    position: absolute;
    border-radius: 50%;
    will-change: transform, opacity;
  }
  .hero-light-ember {
    width: 58%;
    height: 80%;
    left: 4%;
    top: 0%;
    background: radial-gradient(circle, var(--backdrop-ember), transparent 62%);
    animation: hero-drift-a 14s ease-in-out infinite alternate;
  }
  .hero-light-cool {
    width: 50%;
    height: 70%;
    right: -4%;
    top: 8%;
    background: radial-gradient(circle, var(--backdrop-cool), transparent 60%);
    animation: hero-drift-b 18s ease-in-out infinite alternate;
  }
  .hero-light-deep {
    width: 46%;
    height: 56%;
    left: 26%;
    bottom: -14%;
    background: radial-gradient(circle, var(--backdrop-ember-deep), transparent 65%);
    animation: hero-drift-c 11s ease-in-out infinite alternate;
  }
  @keyframes hero-drift-a {
    from { transform: translate3d(-10%, -7%, 0) scale(0.94); opacity: 0.55; }
    to { transform: translate3d(14%, 10%, 0) scale(1.28); opacity: 1; }
  }
  @keyframes hero-drift-b {
    from { transform: translate3d(10%, 8%, 0) scale(1.18); opacity: 1; }
    to { transform: translate3d(-13%, -9%, 0) scale(0.88); opacity: 0.5; }
  }
  @keyframes hero-drift-c {
    from { transform: translate3d(-8%, 5%, 0) scale(0.9); opacity: 0.6; }
    to { transform: translate3d(10%, -8%, 0) scale(1.22); opacity: 1; }
  }
  html[data-motion='reduced'] .hero-light {
    animation: none;
  }

  /* ---- the branching river ---- */
  .hero-river {
    opacity: 0.85;
  }
  .river-glow,
  .river-core {
    stroke-linecap: round;
    fill: none;
  }
  .river-glow {
    stroke-width: 7;
    opacity: 0.25;
  }
  .river-core {
    stroke-width: 1.75;
    opacity: 0.9;
    stroke-dasharray: 90 160;
    animation: river-flow var(--dur, 9s) linear infinite;
  }
  .river-core.river-ember {
    stroke: var(--color-terracotta-400);
  }
  .river-glow.river-ember {
    stroke: var(--color-terracotta-600);
  }
  .river-core.river-ember-dim {
    stroke: var(--color-terracotta-600);
    opacity: 0.6;
  }
  .river-glow.river-ember-dim {
    stroke: var(--color-terracotta-800);
    opacity: 0.18;
  }
  .river-core.river-cool {
    stroke: #7caaff;
    opacity: 0.55;
  }
  .river-glow.river-cool {
    stroke: #7caaff;
    opacity: 0.12;
  }
  @keyframes river-flow {
    to {
      stroke-dashoffset: -250;
    }
  }
  html[data-motion='reduced'] .river-core {
    animation: none;
    stroke-dasharray: none;
    opacity: 0.5;
  }
</style>

<script>
  // Hero parallax: one rAF sampler, transform-only, off for touch + reduced motion,
  // drift clamped to 48px (03 §3.1, §3.3).
  const reduced = document.documentElement.dataset.motion === 'reduced';
  const coarse = window.matchMedia('(pointer: coarse)').matches;
  if (!reduced && !coarse) {
    const els = Array.from(document.querySelectorAll<HTMLElement>('[data-parallax]')).map((el) => ({
      el,
      factor: parseFloat(el.dataset.parallax || '1'),
    }));
    let ticking = false;
    const apply = () => {
      ticking = false;
      const y = window.scrollY;
      for (const { el, factor } of els) {
        const drift = Math.max(-48, Math.min(48, y * (1 - factor)));
        el.style.transform = `translate3d(0, ${drift}px, 0)`;
      }
    };
    window.addEventListener(
      'scroll',
      () => {
        if (!ticking) {
          ticking = true;
          requestAnimationFrame(apply);
        }
      },
      { passive: true }
    );
  }
</script>
