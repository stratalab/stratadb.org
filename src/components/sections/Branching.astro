---
// Section 2 (04 §3 v4): the head lives in the rhythm container; the pinned
// scene breaks out to full bleed — cinema doesn't fit in a prose column.
import SectionShell from '../foundation/SectionShell.astro';
import Heading from '../foundation/Heading.astro';
import BranchScrub from './branch/BranchScrub.tsx';
---

<SectionShell id="branch" eyebrow="BRANCH" class="!pb-0">
  <div class="reveal max-w-[42rem]">
    <Heading size="display">Try anything. Keep what works.</Heading>
    <p class="mt-6 text-body-lg text-ink-mid">
      A branch is a complete database — fork it, change it, diff it, merge it back.
      Forking copies nothing, so it's instant at any size.
    </p>
  </div>
</SectionShell>
<div class="w-full">
  <BranchScrub client:visible />
</div>
