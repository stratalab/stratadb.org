---
// Launch nav (01 §4, 04 §1): Docs · Architecture · Changelog + GitHub + Get Started.
import Button from '../foundation/Button.astro';

const navItems = [
  { label: 'Docs', href: '/docs' },
  { label: 'Architecture', href: '/architecture' },
  { label: 'Changelog', href: '/changelog' },
];
const currentPath = Astro.url.pathname;

// Star count: build-time cached, fails quiet (06 §4 pattern; live hydration later).
let stars: string | null = null;
try {
  const res = await fetch('https://api.github.com/repos/stratalab/strata-core', {
    headers: { Accept: 'application/vnd.github+json' },
  });
  if (res.ok) {
    const data = await res.json();
    if (typeof data.stargazers_count === 'number')
      stars = Intl.NumberFormat('en', { notation: 'compact' }).format(data.stargazers_count);
  }
} catch {
  /* no count — render the icon alone */
}
---

<header class="sticky top-0 z-50 border-b border-line bg-void/85 backdrop-blur-xl">
  <nav class="mx-auto flex h-16 w-full max-w-[70rem] items-center justify-between px-6 max-[480px]:px-4">
    <a href="/" class="flex items-center gap-2.5">
      <svg
        class="h-5 w-5 text-terracotta-500"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        aria-hidden="true"
      >
        <path d="M12 2L2 7l10 5 10-5-10-5z"></path>
        <path d="M2 12l10 5 10-5"></path>
        <path d="M2 17l10 5 10-5"></path>
      </svg>
      <span class="font-semibold text-ink-hi">StrataDB</span>
    </a>

    <div class="hidden items-center gap-1 md:flex">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class:list={[
              'rounded-(--radius-control) px-3.5 py-2 text-small transition-colors duration-200',
              currentPath.startsWith(item.href)
                ? 'text-ink-hi underline decoration-terracotta-500 decoration-2 underline-offset-8'
                : 'text-ink-mid hover:text-ink-hi',
            ]}
          >
            {item.label}
          </a>
        ))
      }
    </div>

    <div class="flex items-center gap-3">
      <a
        href="https://github.com/stratalab/strata-core"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-1.5 rounded-(--radius-control) px-2 py-2 text-ink-low transition-colors duration-200 hover:text-ink-hi"
        aria-label="StrataDB on GitHub"
      >
        <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path
            fill-rule="evenodd"
            clip-rule="evenodd"
            d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
          ></path>
        </svg>
        {stars && <span class="font-mono text-mono-sm">{stars}</span>}
      </a>
      <Button href="/docs/getting-started" class="max-sm:hidden">Get Started</Button>
      <button
        id="nav-toggle"
        class="rounded-(--radius-control) p-2 text-ink-mid hover:text-ink-hi md:hidden"
        aria-label="Menu"
        aria-expanded="false"
      >
        <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" d="M4 7h16M4 12h16M4 17h16"></path>
        </svg>
      </button>
    </div>
  </nav>

  <div id="nav-sheet" class="hidden border-t border-line px-6 pb-4 md:hidden">
    {
      navItems.map((item) => (
        <a href={item.href} class="block py-3 text-small text-ink-mid hover:text-ink-hi">
          {item.label}
        </a>
      ))
    }
    <a href="/docs/getting-started" class="block py-3 text-small text-terracotta-500">Get Started</a>
  </div>
</header>

<script>
  const toggle = document.getElementById('nav-toggle');
  const sheet = document.getElementById('nav-sheet');
  toggle?.addEventListener('click', () => {
    const open = sheet?.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(open));
  });
</script>
