---
// Mobile counterpart to DocsSidebar: the same generated tree, rendered as a
// native-<details> disclosure above the article below lg. Zero JS.
import type { NavSection } from '../../lib/docsNav';

interface Props {
  sections: NavSection[];
  currentPath: string;
}
const { sections, currentPath } = Astro.props;
const isActive = (href: string) => currentPath === href || currentPath === `${href}/`;
const sectionActive = (section: NavSection) =>
  section.items.some((i) => isActive(i.href)) ||
  (section.groups ?? []).some(
    (g) => (g.href && isActive(g.href)) || g.items.some((i) => isActive(i.href))
  );
const current = sections.find(sectionActive);
---

<details class="mb-8 rounded-(--radius-control) border border-line lg:hidden">
  <summary
    class="flex cursor-pointer list-none items-center justify-between px-4 py-3 text-small text-ink-mid"
  >
    <span>
      Docs menu{current && <span class="text-ink-low"> · {current.title}</span>}
    </span>
    <svg
      class="h-4 w-4 shrink-0 text-ink-low"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      viewBox="0 0 24 24"
      aria-hidden="true"
    >
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path>
    </svg>
  </summary>
  <nav class="max-h-[60vh] overflow-y-auto border-t border-line px-4 py-3" aria-label="Documentation">
    {
      sections.map((section) => (
        <details open={sectionActive(section)} class="group/sec mb-1">
          <summary class="flex cursor-pointer list-none items-center gap-1.5 py-1.5 text-eyebrow font-medium uppercase text-ink-low">
            <span class="transition-transform duration-200 group-open/sec:rotate-90">›</span>
            {section.title}
          </summary>
          <ul class="mb-2 ml-2 space-y-px border-l border-line">
            {section.items.map((item) => (
              <li>
                <a
                  href={item.href}
                  class:list={[
                    '-ml-px block border-l-2 py-1.5 pl-4 text-small',
                    isActive(item.href)
                      ? 'border-terracotta-500 text-ink-hi'
                      : 'border-transparent text-ink-mid',
                  ]}
                >
                  {item.title}
                </a>
              </li>
            ))}
            {(section.groups ?? []).map((group) => (
              <li>
                <details
                  open={(group.href && isActive(group.href)) || group.items.some((i) => isActive(i.href))}
                  class="group/fam"
                >
                  <summary class="flex cursor-pointer list-none items-center gap-1.5 py-1.5 pl-4 text-small text-ink-mid">
                    <span class="text-ink-low transition-transform duration-200 group-open/fam:rotate-90">
                      ›
                    </span>
                    {group.href ? <a href={group.href}>{group.title}</a> : group.title}
                  </summary>
                  <ul class="ml-4 space-y-px border-l border-line">
                    {group.items.map((item) => (
                      <li>
                        <a
                          href={item.href}
                          class:list={[
                            '-ml-px block border-l-2 py-1 pl-4 text-small',
                            isActive(item.href)
                              ? 'border-terracotta-500 text-ink-hi'
                              : 'border-transparent text-ink-mid',
                          ]}
                        >
                          {item.title}
                        </a>
                      </li>
                    ))}
                  </ul>
                </details>
              </li>
            ))}
          </ul>
        </details>
      ))
    }
  </nav>
</details>
