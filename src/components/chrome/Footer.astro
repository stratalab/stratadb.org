---
// Footer per 01 §4 / 04 §1. Real links only; "For agents" targets land in Phase 5.
const columns: Record<string, { label: string; href: string; external?: boolean }[]> = {
  Product: [
    { label: 'Strata Foundry', href: 'https://github.com/stratalab/strata-foundry', external: true },
    { label: 'Changelog', href: '/changelog' },
  ],
  Documentation: [
    { label: 'Getting Started', href: '/docs/getting-started' },
    { label: 'Guides', href: '/docs/guides' },
    { label: 'Cookbook', href: '/docs/cookbook' },
    { label: 'Reference', href: '/docs/reference' },
  ],
  Internals: [
    { label: 'Architecture', href: '/architecture' },
    { label: 'strata-core', href: 'https://github.com/stratalab/strata-core', external: true },
    { label: 'strata-foundry', href: 'https://github.com/stratalab/strata-foundry', external: true },
    { label: 'stratahub', href: 'https://github.com/stratalab/stratahub', external: true },
  ],
  'For agents': [
    { label: 'llms.txt', href: '/llms.txt' },
    { label: 'For AI agents', href: '/docs/getting-started/for-agents' },
    { label: 'MCP reference', href: '/docs/reference/mcp' },
  ],
};
const year = new Date().getFullYear();
---

<footer class="border-t border-line">
  <div class="mx-auto w-full max-w-[70rem] px-6 py-16 max-[480px]:px-4">
    <div class="grid grid-cols-2 gap-10 md:grid-cols-4">
      {
        Object.entries(columns).map(([title, links]) => (
          <div>
            <h3 class="mb-4 text-small font-medium text-ink-hi">{title}</h3>
            <ul class="space-y-3">
              {links.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="text-small text-ink-low transition-colors duration-200 hover:text-ink-mid"
                    target={link.external ? '_blank' : undefined}
                    rel={link.external ? 'noopener noreferrer' : undefined}
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
    <div class="mt-14 flex flex-wrap items-center justify-between gap-4 border-t border-line pt-8">
      <p class="font-mono text-mono-sm text-ink-low">
        © {year} StrataDB · Apache-2.0 · Research preview
      </p>
      <a
        href="https://github.com/stratalab/strata-core"
        target="_blank"
        rel="noopener noreferrer"
        class="text-ink-low transition-colors duration-200 hover:text-ink-mid"
        aria-label="GitHub"
      >
        <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path
            fill-rule="evenodd"
            clip-rule="evenodd"
            d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
          ></path>
        </svg>
      </a>
    </div>
  </div>
</footer>
