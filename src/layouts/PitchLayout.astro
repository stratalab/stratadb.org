---
// PRIVATE — Strata engine-internals pitch surface. Own chrome (sticky section
// rail), light "engineering spec-sheet" aesthetic: ruled structure, monospace
// metadata, ember as the single instrument indicator. noindex.
import '../styles/global.css';

interface Section {
  id: string;
  label: string;
}
interface Props {
  title?: string;
  sections: Section[];
}
const { title = 'Strata — engine internals', sections } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />

    <link rel="preload" href="/fonts/GeneralSans-Variable.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/CommitMono-400.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/CommitMono-700.woff2" as="font" type="font/woff2" crossorigin />

    <script is:inline>
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches)
        document.documentElement.dataset.motion = 'reduced';
    </script>
  </head>

  <body class="pitch-light min-h-screen">
    {/* warm-light "pitch" theme tokens live in src/styles/tokens.css (.pitch-light) — literal-drift rule */}

    <div class="pitch-shell">
      <!-- Sticky section rail — the index -->
      <nav class="pitch-rail" aria-label="Sections">
        <a href={`#${sections[0]?.id}`} class="rail-brand">
          <img class="rail-logo" src="/logo.svg" alt="" width="22" height="22" />
          <span class="rail-word">STRATA</span>
        </a>
        <p class="rail-sub">Engine&nbsp;·&nbsp;internals</p>

        <ol class="rail-index">
          {
            sections.map((s, i) => (
              <li>
                <a href={`#${s.id}`} class="rail-item" data-rail-link={s.id}>
                  <span class="rail-dot" aria-hidden="true" />
                  <span class="rail-num">{String(i + 1).padStart(2, '0')}</span>
                  <span class="rail-label">{s.label}</span>
                </a>
              </li>
            ))
          }
        </ol>

        <div class="rail-foot">
          <span class="rail-foot-line" aria-hidden="true" />
          <span class="rail-foot-meta">{sections.length} sections · scroll</span>
        </div>
      </nav>

      <main class="pitch-main">
        <slot />
      </main>
    </div>

    <style>
      /* ---- shell ------------------------------------------------------ */
      .pitch-shell {
        display: grid;
        grid-template-columns: 14.5rem minmax(0, 1fr);
        min-height: 100vh;
      }
      @media (max-width: 900px) {
        .pitch-shell {
          grid-template-columns: 1fr;
        }
      }

      /* ---- rail ------------------------------------------------------- */
      .pitch-rail {
        position: sticky;
        top: 0;
        align-self: start;
        height: 100vh;
        display: flex;
        flex-direction: column;
        padding: 2.1rem 1.5rem 1.6rem;
        border-right: 1px solid var(--color-line);
        background: var(--color-void);
      }
      @media (max-width: 900px) {
        .pitch-rail {
          position: fixed;
          inset: auto 0 0 0;
          height: auto;
          flex-direction: row;
          align-items: center;
          gap: 0.5rem;
          overflow-x: auto;
          padding: 0.6rem 0.9rem;
          border-right: none;
          border-top: 1px solid var(--color-line-hover);
          background: var(--color-panel);
          z-index: 40;
        }
        .rail-sub,
        .rail-foot {
          display: none;
        }
        .rail-index {
          flex-direction: row;
          margin: 0;
          padding: 0;
          border: none;
          gap: 0.1rem;
        }
        .rail-index::before {
          display: none;
        }
        .rail-label,
        .rail-dot {
          display: none;
        }
      }

      .rail-brand {
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
        text-decoration: none;
      }
      .rail-logo {
        width: 1.35rem;
        height: 1.35rem;
        display: block;
      }
      .rail-word {
        font-family: var(--font-sans);
        font-weight: 600;
        letter-spacing: 0.2em;
        font-size: 0.9rem;
        color: var(--color-ink-hi);
      }
      .rail-sub {
        margin-top: 0.5rem;
        font-family: var(--font-mono);
        font-size: 0.625rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--color-ink-low);
      }

      /* the index, on a vertical measure line */
      .rail-index {
        list-style: none;
        position: relative;
        margin: 2.4rem 0 0;
        padding: 0;
        display: flex;
        flex-direction: column;
      }
      .rail-index::before {
        content: '';
        position: absolute;
        left: 3px;
        top: 0.75rem;
        bottom: 0.75rem;
        width: 1px;
        background: var(--color-line);
      }
      .rail-item {
        position: relative;
        display: grid;
        grid-template-columns: 7px auto 1fr;
        align-items: center;
        gap: 0 0.6rem;
        padding: 0.46rem 0;
        text-decoration: none;
      }
      .rail-dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: var(--color-void);
        box-shadow: inset 0 0 0 1.5px var(--color-ink-low);
        transition: box-shadow var(--dur-2) var(--ease-out), background var(--dur-2) var(--ease-out);
      }
      .rail-num {
        font-family: var(--font-mono);
        font-size: 0.6875rem;
        color: var(--color-ink-low);
        transition: color var(--dur-2) var(--ease-out);
      }
      .rail-label {
        font-family: var(--font-mono);
        font-size: 0.72rem;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        color: var(--color-ink-mid);
        transition: color var(--dur-2) var(--ease-out);
      }
      .rail-item:hover .rail-label {
        color: var(--color-ink-hi);
      }
      .rail-item:hover .rail-dot {
        box-shadow: inset 0 0 0 1.5px var(--color-ink-mid);
      }
      .rail-item.is-active .rail-dot {
        background: var(--ember);
        box-shadow: inset 0 0 0 1.5px var(--ember), 0 0 0 3px var(--ember-soft);
      }
      .rail-item.is-active .rail-num {
        color: var(--ember);
      }
      .rail-item.is-active .rail-label {
        color: var(--color-ink-hi);
      }

      .rail-foot {
        margin-top: auto;
        display: flex;
        flex-direction: column;
        gap: 0.7rem;
      }
      .rail-foot-line {
        height: 1px;
        background: var(--color-line);
      }
      .rail-foot-meta {
        font-family: var(--font-mono);
        font-size: 0.625rem;
        letter-spacing: 0.08em;
        color: var(--color-ink-low);
      }

      /* ---- main : the ruled engineering ground ------------------------ */
      .pitch-main {
        min-width: 0;
        background-color: var(--color-void);
        background-image:
          linear-gradient(to right, color-mix(in srgb, var(--color-ink-hi) 3%, transparent) 1px, transparent 1px),
          linear-gradient(to bottom, color-mix(in srgb, var(--color-ink-hi) 3%, transparent) 1px, transparent 1px);
        background-size: 46px 46px;
      }
      @media (max-width: 900px) {
        .pitch-main {
          padding-bottom: 4rem;
        }
      }
    </style>

    <script>
      // Scrollspy — light the rail item for the section nearest the top band.
      const links = new Map<string, HTMLElement>();
      document.querySelectorAll<HTMLElement>('[data-rail-link]').forEach((el) => {
        const id = el.dataset.railLink;
        if (id) links.set(id, el);
      });
      const setActive = (id: string) =>
        links.forEach((el, key) => el.classList.toggle('is-active', key === id));
      const sections = Array.from(links.keys())
        .map((id) => document.getElementById(id))
        .filter((el): el is HTMLElement => el !== null);
      if (sections.length) {
        const io = new IntersectionObserver(
          (entries) => {
            const visible = entries
              .filter((e) => e.isIntersecting)
              .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);
            if (visible[0]?.target.id) setActive(visible[0].target.id);
          },
          { rootMargin: '-45% 0px -45% 0px', threshold: 0 }
        );
        sections.forEach((s) => io.observe(s));
        setActive(sections[0].id);
      }

      // Reveal recipe for .reveal elements.
      const revealed = document.querySelectorAll('.reveal');
      if (revealed.length) {
        const ro = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add('is-revealed');
                ro.unobserve(e.target);
              }
            }
          },
          { threshold: 0.15 }
        );
        revealed.forEach((el) => ro.observe(el));
      }
    </script>
  </body>
</html>
