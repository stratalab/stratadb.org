---
// Docs reading experience, re-skinned with tokens (Phase 5). Prose is owned by
// strata-core (synced); this layout owns presentation only.
import BaseLayout from './BaseLayout.astro';
import DocsSidebar from '../components/chrome/DocsSidebar.astro';
import { docsNav } from '../lib/docsNav';

interface Props {
  title: string;
  description?: string;
  mdHref?: string;
}
const { title, description, mdHref } = Astro.props;
const sections = await docsNav();
const currentPath = Astro.url.pathname.replace(/\/$/, '');
---

<BaseLayout title={`${title} — StrataDB Docs`} description={description}>
  <div class="mx-auto w-full max-w-[70rem] px-6 py-12 max-[480px]:px-4">
    <div class="flex gap-12">
      <DocsSidebar sections={sections} currentPath={currentPath} />
      <article class="min-w-0 flex-1">
        <div class="prose-docs">
          <slot />
        </div>
        {
          mdHref && (
            <p class="mt-16 border-t border-line pt-6 font-mono text-mono-sm text-ink-low">
              agents: this page as markdown →{' '}
              <a href={mdHref} class="text-ink-mid transition-colors duration-200 hover:text-ink-hi">
                {mdHref}
              </a>
            </p>
          )
        }
      </article>
    </div>
  </div>
</BaseLayout>
