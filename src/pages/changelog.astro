---
// Generated from real release data (PRD §7.2) — the sibling-path read with the
// stale hardcoded fallback is dead. Build-time fetch; committed release.json
// is the single-entry floor if the API is unreachable.
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionShell from '../components/foundation/SectionShell.astro';
import Heading from '../components/foundation/Heading.astro';
import release from '../data/release.json';

interface Release {
  tag: string;
  name: string;
  date: string;
  body: string;
}

let releases: Release[] = [];
try {
  const res = await fetch('https://api.github.com/repos/stratalab/strata-core/releases?per_page=20', {
    headers: { Accept: 'application/vnd.github+json' },
  });
  if (res.ok) {
    const data = await res.json();
    releases = data.map((r: any) => ({
      tag: r.tag_name,
      name: r.name || r.tag_name,
      date: (r.published_at ?? '').slice(0, 10),
      body: r.body ?? '',
    }));
  }
} catch {
  /* fall through to floor */
}
if (!releases.length) {
  releases = [
    {
      tag: `v${release.version}`,
      name: `v${release.version}`,
      date: release.fetched_at,
      body: 'Release notes on GitHub.',
    },
  ];
}
---

<BaseLayout title="Changelog — StrataDB" description="StrataDB release history, generated from GitHub releases.">
  <SectionShell eyebrow="CHANGELOG">
    <div class="mb-12 max-w-[42rem]">
      <Heading level={1} size="display">Every version. Here too.</Heading>
      <p class="mt-6 text-body-lg text-ink-mid">
        Generated from <a
          href="https://github.com/stratalab/strata-core/releases"
          class="text-terracotta-500 underline decoration-terracotta-700 underline-offset-4 transition-colors duration-200 hover:text-terracotta-400"
          target="_blank"
          rel="noopener noreferrer">GitHub releases</a
        > at build time.
      </p>
    </div>

    <div class="max-w-[46rem] space-y-10">
      {
        releases.map((r, i) => (
          <article id={r.tag} class="border-l-2 border-line pl-6">
            <div class="flex items-baseline gap-3">
              <h2 class="font-mono text-heading text-ink-hi">
                <a href={`#${r.tag}`} class="transition-colors duration-200 hover:text-terracotta-400">
                  {r.tag}
                </a>
              </h2>
              {i === 0 && (
                <span class="rounded-full border border-line px-2.5 py-0.5 font-mono text-mono-sm text-terracotta-500">
                  latest
                </span>
              )}
              <span class="font-mono text-mono-sm text-ink-low">{r.date}</span>
            </div>
            {r.body && <pre class="mt-4 whitespace-pre-wrap font-sans text-small leading-6 text-ink-mid">{r.body}</pre>}
          </article>
        ))
      }
    </div>
  </SectionShell>
</BaseLayout>
