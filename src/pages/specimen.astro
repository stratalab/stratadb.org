---
// PERMANENT (2026-06-12): the shared-foundation reference for the Strata family.
// Foundry's token adoption (Doc 02 Appendix B) is checked against this page —
// site and studio must read as one product. Never delete; stays noindex.
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionShell from '../components/foundation/SectionShell.astro';
import Eyebrow from '../components/foundation/Eyebrow.astro';
import Heading from '../components/foundation/Heading.astro';
import Badge from '../components/foundation/Badge.astro';
import Button from '../components/foundation/Button.astro';
import CopyChip from '../components/foundation/CopyChip.astro';
import StatStrip from '../components/foundation/StatStrip.astro';
import Card from '../components/foundation/Card.astro';
import HorizonGlow from '../components/foundation/HorizonGlow.astro';
import TerminalFrame from '../components/chrome/TerminalFrame.astro';
import TermLine from '../components/chrome/TermLine.astro';

const terracotta = ['50', '100', '200', '300', '400', '500', '600', '700', '800', '900', '950'];
const sediment = terracotta;
const strata = ['kv', 'event', 'json', 'vector', 'graph'];
---

<BaseLayout title="Specimen — StrataDB design system" noindex>
  <SectionShell eyebrow="SPECIMEN · PHASE 1">
    <Heading level={1} size="title">Tokens, type, and chrome — the font-veto page.</Heading>
    <p class="mt-3 max-w-[42.5rem] text-body text-ink-mid">
      Everything below renders from <code class="font-mono text-mono-sm">tokens.css</code> only.
      General Sans carries display and body; Commit Mono carries everything that is code,
      data, or a measurement.
    </p>
  </SectionShell>

  <SectionShell eyebrow="TYPE SCALE">
    <div class="space-y-10">
      <div>
        <p class="mb-2 font-mono text-mono-sm text-ink-low">display-xl · 92/0.98 · 600 · −3.5%</p>
        <p class="text-display-xl text-ink-hi">An embedded database.</p>
      </div>
      <div>
        <p class="mb-2 font-mono text-mono-sm text-ink-low">display · 64/1.02 · 600 · −2.5%</p>
        <p class="text-display text-ink-hi">Try anything. Keep what works.</p>
      </div>
      <div>
        <p class="mb-2 font-mono text-mono-sm text-ink-low">title · 40/1.1 · 600 · −1.5%</p>
        <p class="text-title text-ink-hi">Go back to any moment.</p>
      </div>
      <div>
        <p class="mb-2 font-mono text-mono-sm text-ink-low">heading · 24/1.25 · 600</p>
        <p class="text-heading text-ink-hi">Every kind of data. One file.</p>
      </div>
      <div>
        <p class="mb-2 font-mono text-mono-sm text-ink-low">body-lg · 19/1.55</p>
        <p class="max-w-[42.5rem] text-body-lg text-ink-mid">
          Forking is O(1) — nothing is copied, at any size. A branch is a complete database:
          diff it, merge it, cherry-pick a single change across.
        </p>
      </div>
      <div>
        <p class="mb-2 font-mono text-mono-sm text-ink-low">body · 16/1.6</p>
        <p class="max-w-[42.5rem] text-body text-ink-mid">
          Ask in plain language. One flag embeds every write as it lands; hybrid retrieval
          searches every primitive at once. Point it at any OpenAI-compatible endpoint — or
          run models locally.
        </p>
      </div>
      <div>
        <p class="mb-2 font-mono text-mono-sm text-ink-low">eyebrow · 13/1 · 500 · +6% caps</p>
        <Eyebrow>Time travel</Eyebrow>
      </div>
      <div>
        <p class="mb-2 font-mono text-mono-sm text-ink-low">stat · 56/1 · 500 · tabular (Commit Mono)</p>
        <p class="font-mono text-stat text-ink-hi">250K · &lt;1 ms · 0</p>
      </div>
    </div>
  </SectionShell>

  <SectionShell eyebrow="COLOR">
    <div class="space-y-8">
      <div>
        <p class="mb-3 font-mono text-mono-sm text-ink-low">terracotta — identity, used surgically</p>
        <div class="flex overflow-hidden rounded-(--radius-control)">
          {terracotta.map((step) => (
            <div class="h-12 flex-1" style={`background: var(--color-terracotta-${step})`} title={`terracotta-${step}`} />
          ))}
        </div>
      </div>
      <div>
        <p class="mb-3 font-mono text-mono-sm text-ink-low">sediment — warm neutrals, never blue-gray</p>
        <div class="flex overflow-hidden rounded-(--radius-control)">
          {sediment.map((step) => (
            <div class="h-12 flex-1" style={`background: var(--color-sediment-${step})`} title={`sediment-${step}`} />
          ))}
        </div>
      </div>
      <div>
        <p class="mb-3 font-mono text-mono-sm text-ink-low">the five primitives</p>
        <div class="flex flex-wrap gap-3">
          {
            strata.map((p) => (
              <div class="flex items-center gap-2 rounded-(--radius-control) border border-line px-3 py-2">
                <span class="h-3 w-3 rounded-full" style={`background: var(--color-strata-${p})`} />
                <span class="font-mono text-mono-sm text-ink-mid">{p}</span>
              </div>
            ))
          }
        </div>
      </div>
      <div>
        <p class="mb-3 font-mono text-mono-sm text-ink-low">surfaces</p>
        <div class="grid grid-cols-2 gap-3 md:grid-cols-4">
          <div class="rounded-(--radius-card) border border-line bg-void p-4 font-mono text-mono-sm text-ink-low">void</div>
          <div class="rounded-(--radius-card) border border-line bg-panel p-4 font-mono text-mono-sm text-ink-low">panel</div>
          <div class="rounded-(--radius-card) border border-line bg-raised p-4 font-mono text-mono-sm text-ink-low">raised</div>
          <div class="rounded-(--radius-card) border border-line bg-inset p-4 font-mono text-mono-sm text-ink-low">inset</div>
        </div>
      </div>
    </div>
  </SectionShell>

  <SectionShell eyebrow="COMPONENTS">
    <div class="space-y-10">
      <div class="flex flex-wrap items-center gap-4">
        <Button href="#">Get Started</Button>
        <Button href="#" variant="quiet">Star on GitHub</Button>
        <Badge href="#">Research preview · v0.12</Badge>
      </div>
      <div>
        <CopyChip value="curl -fsSL stratadb.org/install.sh | sh" />
      </div>
      <StatStrip
        items={[
          { value: '250K ops/s', note: 'single thread, Cache mode' },
          { value: '<1 ms fork', note: 'branch fork, any size' },
          { value: '5 primitives' },
          { value: '0 servers' },
          { value: 'Apache-2.0' },
        ]}
      />
      <div class="grid gap-4 md:grid-cols-3">
        <Card href="#">
          <h3 class="mb-2 text-heading text-ink-hi">Documentation</h3>
          <p class="text-small text-ink-mid">Concepts, guides, and the full reference.</p>
        </Card>
        <Card href="#">
          <h3 class="mb-2 text-heading text-ink-hi">Examples &amp; quickstarts</h3>
          <p class="text-small text-ink-mid">First database in thirty seconds; real patterns after that.</p>
        </Card>
        <Card href="#">
          <h3 class="mb-2 text-heading text-ink-hi">Whitepapers</h3>
          <p class="text-small text-ink-mid">The internals, written down: storage engine, concurrency model, durability and recovery.</p>
        </Card>
      </div>
    </div>
  </SectionShell>

  <SectionShell eyebrow="TERMINAL CHROME">
    <div class="max-w-[42.5rem]">
      <TerminalFrame title="strata — first write" status="engine: scripted replay">
        <TermLine cmd>kv put hello world</TermLine>
        <TermLine>(version) 1</TermLine>
        <TermLine cmd>kv get hello</TermLine>
        <TermLine>"world"</TermLine>
        <TermLine cmd branch="experiment">kv get hello</TermLine>
        <TermLine tone="nil">(nil)</TermLine>
        <TermLine cmd>branch diff experiment</TermLine>
        <TermLine tone="ok">+1 key · hello</TermLine>
      </TerminalFrame>
    </div>
  </SectionShell>

  <section class="relative overflow-hidden py-32 max-md:py-20">
    <HorizonGlow />
    <div class="relative mx-auto w-full max-w-[70rem] px-6 text-center">
      <Eyebrow class="mb-4">The horizon — one of two permitted instances</Eyebrow>
      <p class="font-mono text-stat text-ink-hi">pip install stratadb</p>
    </div>
  </section>
</BaseLayout>
