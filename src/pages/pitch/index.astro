---
// PRIVATE pitch surface — Strata engine, "engineering spec-sheet" aesthetic.
// §1–§2 built; §3–§7 anchored placeholders, filled one at a time.
import PitchLayout from '../../layouts/PitchLayout.astro';

const sections = [
  { id: 'what-it-is', label: 'What it is' },
  { id: 'where-it-fits', label: 'Where it fits' },
  { id: 'what-it-does', label: 'What it does' },
  { id: 'architecture', label: 'Architecture' },
  { id: 'testing', label: 'How we test' },
  { id: 'benchmarks', label: 'Benchmarks' },
  { id: 'why', label: 'Why it matters' },
];

const pending = [
  { id: 'testing', n: '05', name: 'How we test', tag: 'correctness', title: 'Coverage measured by bug class.' },
  { id: 'benchmarks', n: '06', name: 'Benchmarks', tag: 'the numbers', title: 'The numbers.' },
  { id: 'why', n: '07', name: 'Why it matters', tag: 'the transfer', title: 'Systems facts with product consequences.' },
];
---

<PitchLayout title="Strata — engine internals" sections={sections}>
  <!-- §1 · WHAT IT IS -->
  <section id="what-it-is" class="pitch-section" aria-label="What Strata is">
    <div class="pitch-wrap">
      <header class="sec-header reveal">
        <span class="sec-id"><span class="sec-hash">§</span>&thinsp;01<span class="sec-name">What it is</span></span>
        <span class="sec-tag">the substrate</span>
      </header>

      <div class="sec-body">
        <div class="open-grid">
          <div class="open-statement reveal">
            <h1 class="open-product">Strata is an embedded database for AI&nbsp;agents.</h1>
            <p class="open-technical">A branch-aware, MVCC, log-structured key-value store — KV, JSON, events, vectors, and graph as capabilities over one&nbsp;substrate.</p>
          </div>

          <aside class="substrate reveal" style="transition-delay: 110ms" aria-label="One substrate">
            <div class="substrate-body">
              <p class="substrate-tag">capabilities</p>
              <div class="cap-row">
                <span class="cap" style="--hue: var(--color-strata-kv)">KV</span>
                <span class="cap" style="--hue: var(--color-strata-json)">JSON</span>
                <span class="cap" style="--hue: var(--color-strata-event)">Event</span>
                <span class="cap" style="--hue: var(--color-strata-vector)">Vector</span>
                <span class="cap" style="--hue: var(--color-strata-graph)">Graph</span>
              </div>
              <p class="substrate-over">over one substrate</p>
              <div class="base">
                <span class="base-name">branch-aware · MVCC · LSM</span>
                <div class="lsm" aria-hidden="true">
                  <div class="lsm-row"><span class="lsm-lab">mem</span><span class="lsm-bar lsm-hot" style="width: 26%"></span></div>
                  <div class="lsm-row"><span class="lsm-lab">L0</span><span class="lsm-bar" style="width: 46%"></span></div>
                  <div class="lsm-row"><span class="lsm-lab">L1</span><span class="lsm-bar" style="width: 70%"></span></div>
                  <div class="lsm-row"><span class="lsm-lab">L2</span><span class="lsm-bar" style="width: 96%"></span></div>
                </div>
              </div>
            </div>
          </aside>
        </div>
      </div>
    </div>
  </section>

  <!-- §2 · WHERE IT FITS -->
  <section id="where-it-fits" class="pitch-section" aria-label="Where Strata fits">
    <div class="pitch-wrap">
      <header class="sec-header reveal">
        <span class="sec-id"><span class="sec-hash">§</span>&thinsp;02<span class="sec-name">Where it fits</span></span>
        <span class="sec-tag">the lineage</span>
      </header>

      <div class="sec-body">
        <h2 class="sec-title reveal">Every era gets an embedded database.</h2>
        <p class="sec-lead reveal" style="transition-delay: 60ms">
          Every era of computing creates a new database class — each in two forms, server and embedded.
        </p>

        <div class="data-panel reveal" style="transition-delay: 110ms">
          <table class="lineage">
            <thead>
              <tr>
                <th scope="col" class="c-era">Era</th>
                <th scope="col">Server</th>
                <th scope="col" class="c-emb">Embedded</th>
              </tr>
            </thead>
            <tbody>
              <tr><th scope="row">Relational</th><td>Oracle · Postgres</td><td class="emb">SQLite</td></tr>
              <tr><th scope="row">Analytics</th><td>Snowflake · BigQuery</td><td class="emb">DuckDB</td></tr>
              <tr><th scope="row">Vector</th><td>Pinecone</td><td class="emb">LanceDB · Chroma</td></tr>
              <tr class="row-agent"><th scope="row">Agent state</th><td class="twin">Redis</td><td class="emb strata">Strata</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- §3 · WHAT IT DOES -->
  <section id="what-it-does" class="pitch-section" aria-label="What Strata does">
    <div class="pitch-wrap">
      <header class="sec-header reveal">
        <span class="sec-id"><span class="sec-hash">§</span>&thinsp;03<span class="sec-name">What it does</span></span>
        <span class="sec-tag">capabilities</span>
      </header>

      <div class="sec-body">
        <h2 class="sec-title reveal">Operations on an agent's state.</h2>

        <div class="cap-figs">
          <!-- Fig 01 · branch tree -->
          <div class="cap-fig reveal">
            <div class="cap-fig-text">
              <p class="cap-fig-kicker">Fig 01</p>
              <h3 class="cap-fig-name">Branch &amp; fork</h3>
              <p class="cap-fig-desc">An agent can fork the whole database to try a change in isolation. If it works the branch is kept; if not it is discarded, without affecting the parent. Forks are cheap enough to explore several alternatives at once.</p>
              <p class="cap-fig-mech">copy-on-write inheritance · fork is O(metadata), not O(data)</p>
            </div>
            <figure class="cap-fig-svg">
              <svg viewBox="0 0 240 100" fill="none" aria-hidden="true">
                <line x1="20" y1="64" x2="220" y2="64" style="stroke:var(--color-ink-mid);stroke-width:1.5" />
                <path d="M92 64 C 116 64, 124 34, 150 34 L 202 34" style="stroke:var(--ember);stroke-width:1.5" />
                <circle cx="36" cy="64" r="4.5" style="fill:var(--color-panel);stroke:var(--color-ink-mid);stroke-width:1.5" />
                <circle cx="92" cy="64" r="4.5" style="fill:var(--color-panel);stroke:var(--color-ink-mid);stroke-width:1.5" />
                <circle cx="148" cy="64" r="4.5" style="fill:var(--color-panel);stroke:var(--color-ink-mid);stroke-width:1.5" />
                <circle cx="204" cy="64" r="4.5" style="fill:var(--color-panel);stroke:var(--color-ink-mid);stroke-width:1.5" />
                <circle cx="150" cy="34" r="4.5" style="fill:var(--color-panel);stroke:var(--ember);stroke-width:1.5" />
                <circle cx="202" cy="34" r="4.5" style="fill:var(--color-panel);stroke:var(--ember);stroke-width:1.5" />
                <text x="20" y="86" style="font-family:var(--font-mono);font-size:9px;fill:var(--color-ink-low)">main</text>
                <text x="184" y="22" style="font-family:var(--font-mono);font-size:9px;fill:var(--ember)">fork</text>
              </svg>
            </figure>
          </div>

          <!-- Fig 02 · version timeline -->
          <div class="cap-fig reveal" style="transition-delay: 70ms">
            <div class="cap-fig-text">
              <p class="cap-fig-kicker">Fig 02</p>
              <h3 class="cap-fig-name">Time-travel &amp; diff</h3>
              <p class="cap-fig-desc">Every version of every value is retained, so the database can be read as of any past point — to reproduce what an agent saw at a given step, compare two versions, or roll back a write without rebuilding state.</p>
              <p class="cap-fig-mech">one versioned row chain · as-of reads from ordering (MVCC)</p>
            </div>
            <figure class="cap-fig-svg">
              <svg viewBox="0 0 240 100" fill="none" aria-hidden="true">
                <line x1="20" y1="60" x2="220" y2="60" style="stroke:var(--color-ink-mid);stroke-width:1.5" />
                <circle cx="32" cy="60" r="4.5" style="fill:var(--color-panel);stroke:var(--color-ink-mid);stroke-width:1.5" />
                <circle cx="80" cy="60" r="5.5" style="fill:var(--ember);stroke:var(--ember)" />
                <circle cx="128" cy="60" r="4.5" style="fill:var(--color-panel);stroke:var(--color-ink-mid);stroke-width:1.5" />
                <circle cx="176" cy="60" r="4.5" style="fill:var(--color-panel);stroke:var(--color-ink-mid);stroke-width:1.5" />
                <circle cx="216" cy="60" r="4.5" style="fill:var(--color-panel);stroke:var(--color-ink-mid);stroke-width:1.5" />
                <line x1="80" y1="26" x2="80" y2="52" style="stroke:var(--ember);stroke-width:1.5" />
                <path d="M75 46 L80 53 L85 46 Z" style="fill:var(--ember)" />
                <text x="62" y="20" style="font-family:var(--font-mono);font-size:9px;fill:var(--ember)">as of</text>
                <text x="26" y="82" style="font-family:var(--font-mono);font-size:8.5px;fill:var(--color-ink-low)">v1</text>
                <text x="74" y="82" style="font-family:var(--font-mono);font-size:8.5px;fill:var(--color-ink-low)">v2</text>
                <text x="122" y="82" style="font-family:var(--font-mono);font-size:8.5px;fill:var(--color-ink-low)">v3</text>
                <text x="170" y="82" style="font-family:var(--font-mono);font-size:8.5px;fill:var(--color-ink-low)">v4</text>
                <text x="210" y="82" style="font-family:var(--font-mono);font-size:8.5px;fill:var(--color-ink-low)">v5</text>
              </svg>
            </figure>
          </div>

          <!-- Fig 03 · primitives → substrate -->
          <div class="cap-fig reveal" style="transition-delay: 140ms">
            <div class="cap-fig-text">
              <p class="cap-fig-kicker">Fig 03</p>
              <h3 class="cap-fig-name">Multi-modal state</h3>
              <p class="cap-fig-desc">Key-value, JSON, events, vectors, and graph are served from one store in a single consistent snapshot, so an agent's working state, structured facts, and embeddings all live in one place.</p>
              <p class="cap-fig-mech">five primitives · capabilities over one substrate</p>
            </div>
            <figure class="cap-fig-svg">
              <svg viewBox="0 0 240 100" fill="none" aria-hidden="true">
                <rect x="16" y="14" width="16" height="16" rx="2.5" style="fill:var(--color-strata-kv)" />
                <rect x="64" y="14" width="16" height="16" rx="2.5" style="fill:var(--color-strata-json)" />
                <rect x="112" y="14" width="16" height="16" rx="2.5" style="fill:var(--color-strata-event)" />
                <rect x="160" y="14" width="16" height="16" rx="2.5" style="fill:var(--color-strata-vector)" />
                <rect x="208" y="14" width="16" height="16" rx="2.5" style="fill:var(--color-strata-graph)" />
                <line x1="24" y1="30" x2="24" y2="56" style="stroke:var(--color-line-hover);stroke-width:1.25" />
                <line x1="72" y1="30" x2="72" y2="56" style="stroke:var(--color-line-hover);stroke-width:1.25" />
                <line x1="120" y1="30" x2="120" y2="56" style="stroke:var(--color-line-hover);stroke-width:1.25" />
                <line x1="168" y1="30" x2="168" y2="56" style="stroke:var(--color-line-hover);stroke-width:1.25" />
                <line x1="216" y1="30" x2="216" y2="56" style="stroke:var(--color-line-hover);stroke-width:1.25" />
                <rect x="16" y="56" width="208" height="24" rx="4" style="fill:color-mix(in srgb, var(--color-ink-hi) 6%, var(--color-panel));stroke:var(--color-ink-mid);stroke-width:1.25" />
                <text x="120" y="71" text-anchor="middle" style="font-family:var(--font-mono);font-size:9px;fill:var(--color-ink-mid)">one substrate</text>
              </svg>
            </figure>
          </div>

          <!-- Fig 04 · hardware range -->
          <div class="cap-fig reveal" style="transition-delay: 210ms">
            <div class="cap-fig-text">
              <p class="cap-fig-kicker">Fig 04</p>
              <h3 class="cap-fig-name">Embedded</h3>
              <p class="cap-fig-desc">Strata links into the application and runs in-process, with no separate server or network round-trip. The same engine runs from a Raspberry Pi to server-class hardware.</p>
              <p class="cap-fig-mech">self-contained Rust · flash- and disk-friendly</p>
            </div>
            <figure class="cap-fig-svg">
              <svg viewBox="0 0 240 100" fill="none" aria-hidden="true">
                <rect x="16" y="50" width="44" height="26" rx="3" style="fill:var(--color-panel);stroke:var(--color-ink-mid);stroke-width:1.5" />
                <rect x="33" y="59" width="10" height="8" rx="1.5" style="fill:var(--ember)" />
                <rect x="82" y="40" width="56" height="36" rx="3" style="fill:var(--color-panel);stroke:var(--color-ink-mid);stroke-width:1.5" />
                <rect x="103" y="53" width="14" height="10" rx="1.5" style="fill:var(--ember)" />
                <rect x="160" y="28" width="64" height="48" rx="3" style="fill:var(--color-panel);stroke:var(--color-ink-mid);stroke-width:1.5" />
                <rect x="184" y="46" width="16" height="12" rx="1.5" style="fill:var(--ember)" />
                <text x="22" y="90" style="font-family:var(--font-mono);font-size:9px;fill:var(--color-ink-low)">Pi</text>
                <text x="92" y="90" style="font-family:var(--font-mono);font-size:9px;fill:var(--color-ink-low)">laptop</text>
                <text x="174" y="90" style="font-family:var(--font-mono);font-size:9px;fill:var(--color-ink-low)">server</text>
              </svg>
            </figure>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- §4 · ARCHITECTURE — the storage engine (L1–L9 explorer) -->
  <section id="architecture" class="pitch-section" aria-label="Architecture — the storage engine">
    <div class="pitch-wrap">
      <header class="sec-header reveal">
        <span class="sec-id"><span class="sec-hash">§</span>&thinsp;04<span class="sec-name">Architecture</span></span>
        <span class="sec-tag">the storage engine</span>
      </header>

      <div class="sec-body">
        <div class="arch-intro reveal">
          <h2 class="sec-title">Inside the storage engine.</h2>
          <p class="sec-lead">A branch-isolated, MVCC, log-structured key-value store, built in nine layers from backend I/O up to the public API. The storage layers handle durability and versioning; the engine adds the five primitives on top.</p>
        </div>

        <div class="explorer reveal" style="transition-delay: 90ms">
          <nav class="explorer-index" aria-label="Storage layers">
            <p class="explorer-tag">storage · nine layers · API → backend IO</p>
            <ul class="explorer-list">
              <li>
                <button type="button" class="explorer-node" data-node="boundary">
                  <span class="explorer-node-k">L9</span>
                  <span class="explorer-node-name">Storage API boundary</span>
                  <span class="explorer-node-sub">the public API</span>
                </button>
              </li>
              <li>
                <button type="button" class="explorer-node" data-node="lifecycle">
                  <span class="explorer-node-k">L8</span>
                  <span class="explorer-node-name">Lifecycle &amp; recovery</span>
                  <span class="explorer-node-sub">states &amp; back-pressure</span>
                </button>
              </li>
              <li>
                <button type="button" class="explorer-node" data-node="commit">
                  <span class="explorer-node-k">L7</span>
                  <span class="explorer-node-name">Commit runtime</span>
                  <span class="explorer-node-sub">version + timestamp</span>
                </button>
              </li>
              <li>
                <button type="button" class="explorer-node is-active" data-node="branch">
                  <span class="explorer-node-k">L6</span>
                  <span class="explorer-node-name">Branch-isolated LSM</span>
                  <span class="explorer-node-sub">COW MVCC forest</span>
                </button>
              </li>
              <li>
                <button type="button" class="explorer-node" data-node="lsm">
                  <span class="explorer-node-k">L5</span>
                  <span class="explorer-node-name">Table runtime</span>
                  <span class="explorer-node-sub">the LSM</span>
                </button>
              </li>
              <li>
                <button type="button" class="explorer-node" data-node="durability">
                  <span class="explorer-node-k">L4</span>
                  <span class="explorer-node-name">Durability spine</span>
                  <span class="explorer-node-sub">visible × durable</span>
                </button>
              </li>
              <li>
                <button type="button" class="explorer-node" data-node="format">
                  <span class="explorer-node-k">L3</span>
                  <span class="explorer-node-name">Durable format</span>
                  <span class="explorer-node-sub">the row key</span>
                </button>
              </li>
              <li>
                <button type="button" class="explorer-node" data-node="layout">
                  <span class="explorer-node-k">L2</span>
                  <span class="explorer-node-name">Object layout</span>
                  <span class="explorer-node-sub">the namespace</span>
                </button>
              </li>
              <li>
                <button type="button" class="explorer-node" data-node="backendio">
                  <span class="explorer-node-k">L1</span>
                  <span class="explorer-node-name">Backend IO</span>
                  <span class="explorer-node-sub">object-first</span>
                </button>
              </li>
            </ul>
          </nav>

          <div class="explorer-detail">
            <!-- branch -->
            <article class="explorer-pane is-active" data-pane="branch">
              <div class="pane-head">
                <span class="pane-layer">L6</span>
                <h3 class="pane-name">Branch-isolated MVCC runtime</h3>
              </div>
              <p class="pane-desc">A branch is a copy-on-write fork of one versioned key space. Forking copies the branch's metadata and points it at the parent's existing data layers, so a new branch is cheap to create regardless of how much data it holds. Each key keeps a single chain of versions, ordered newest-first; latest, as-of, and history reads all walk that one chain.</p>
              <div class="bf" data-bf aria-label="Interactive: fork a branch, write to each, watch one key's reads diverge">
                <div class="bf-stage">
                  <div class="bf-key">key <b>k</b> · a read returns the newest version</div>
                  <div class="bf-heads">
                    <div class="bf-head">
                      <span class="bf-head-label">main</span>
                      <div class="bf-cells" data-bf-mainhead></div>
                    </div>
                    <div class="bf-head">
                      <span class="bf-head-label">fork</span>
                      <div class="bf-cells" data-bf-forkhead></div>
                    </div>
                  </div>
                  <div class="bf-gate" data-bf-gate hidden>fork-version gate · v5</div>
                  <div class="bf-base">
                    <span class="bf-base-label" data-bf-baselabel>main · versions of k</span>
                    <div class="bf-cells bf-base-cells" data-bf-base></div>
                  </div>
                  <div class="bf-reads">
                    <span class="bf-read" data-bf-readmain>main reads k = <b>c</b></span>
                    <span class="bf-read" data-bf-readfork hidden>fork reads k = <b>—</b></span>
                  </div>
                </div>
                <p class="lsm-note" data-bf-note>main holds one key k with three versions, newest first. A read returns the newest.</p>
                <div class="lsm-controls">
                  <button type="button" class="lsm-btn" data-bf-reset>⟲ reset</button>
                  <button type="button" class="lsm-btn" data-bf-prev aria-label="Step back">◂</button>
                  <button type="button" class="lsm-btn lsm-btn-primary" data-bf-next>step ▸</button>
                  <button type="button" class="lsm-btn" data-bf-play>play</button>
                  <span class="lsm-count" data-bf-count>0 / 4</span>
                </div>
              </div>
              <p class="pane-show"><span class="pane-show-k">// show me</span>fork = O(metadata)&nbsp;&nbsp;·&nbsp;&nbsp;child shares parent layers by reference&nbsp;&nbsp;·&nbsp;&nbsp;inherited visible = min(req, fork_version)</p>
            </article>

            <!-- lsm -->
            <article class="explorer-pane" data-pane="lsm">
              <div class="pane-head">
                <span class="pane-layer">L5</span>
                <h3 class="pane-name">Table runtime — the LSM</h3>
              </div>
              <p class="pane-desc">Writes land in an in-memory table, then flush to immutable L0 tables and merge down the levels through compaction. The runtime keeps no retention policy of its own. The caller passes in which versions a compaction is allowed to drop, so versioning and garbage collection are decided by the layer above it.</p>
              <div class="lsm" data-lsm aria-label="Interactive: an LSM write — flush, compaction, and read">
                <div class="lsm-stage">
                  <span class="lsm-read" data-lsm-read hidden>read b</span>
                  <div class="lsm-level" data-lsm-level="mem">
                    <span class="lsm-tag">mem</span>
                    <div class="lsm-slots" data-lsm-mem></div>
                    <span class="lsm-meta" data-lsm-memmeta>0 / 3</span>
                  </div>
                  <div class="lsm-flow" data-lsm-flow="flush"><span>↓ flush</span></div>
                  <div class="lsm-level" data-lsm-level="l0">
                    <span class="lsm-tag">L0</span>
                    <div class="lsm-tiles" data-lsm-l0></div>
                    <span class="lsm-meta">overlapping</span>
                  </div>
                  <div class="lsm-flow" data-lsm-flow="compact"><span>↓ compaction</span><em>policy: prune · tombstone · TTL</em></div>
                  <div class="lsm-level" data-lsm-level="l1">
                    <span class="lsm-tag">L1</span>
                    <div class="lsm-runs" data-lsm-l1></div>
                    <span class="lsm-meta">sorted</span>
                  </div>
                  <div class="lsm-level lsm-level-base" data-lsm-level="l2">
                    <span class="lsm-tag">L2</span>
                    <div class="lsm-base"></div>
                  </div>
                </div>
                <p class="lsm-note" data-lsm-note>An LSM batches writes in memory, then flushes sorted tables to disk. Step&nbsp;▸ to follow one through.</p>
                <div class="lsm-controls">
                  <button type="button" class="lsm-btn" data-lsm-reset>⟲ reset</button>
                  <button type="button" class="lsm-btn" data-lsm-prev aria-label="Step back">◂</button>
                  <button type="button" class="lsm-btn lsm-btn-primary" data-lsm-next>step ▸</button>
                  <button type="button" class="lsm-btn" data-lsm-play>play</button>
                  <span class="lsm-count" data-lsm-count>00 / 14</span>
                </div>
              </div>
              <p class="pane-show"><span class="pane-show-k">// show me</span>compaction(prune · tombstone · TTL) — caller-supplied&nbsp;&nbsp;·&nbsp;&nbsp;L0 overlaps · L1+ sorted by range</p>
            </article>

            <!-- durability -->
            <article class="explorer-pane" data-pane="durability">
              <div class="pane-head">
                <span class="pane-layer">L4</span>
                <h3 class="pane-name">Durability spine</h3>
              </div>
              <p class="pane-desc">Visibility and durability are tracked as separate states. A write can become visible before its durability is confirmed, and if the process crashes during that window, recovery resolves each affected write to a specific outcome — durable, or visible with durability unconfirmed — and reports which is which.</p>
              <figure class="pane-svg">
                <svg viewBox="0 0 360 152" fill="none" aria-hidden="true">
