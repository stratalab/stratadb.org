---
// PRIVATE pitch surface — Strata engine, "engineering spec-sheet" aesthetic.
// §1–§2 built; §3–§7 anchored placeholders, filled one at a time.
import PitchLayout from '../../layouts/PitchLayout.astro';

const sections = [
  { id: 'what-it-is', label: 'What it is' },
  { id: 'where-it-fits', label: 'Where it fits' },
  { id: 'what-it-does', label: 'What it does' },
  { id: 'architecture', label: 'Architecture' },
  { id: 'testing', label: 'How we test' },
  { id: 'benchmarks', label: 'Benchmarks' },
  { id: 'why', label: 'Why it matters' },
];

const pending = [
  { id: 'what-it-does', n: '03', name: 'What it does', tag: 'capabilities', title: 'Branch · time-travel · one store · runs anywhere.' },
  { id: 'architecture', n: '04', name: 'Architecture', tag: 'the engine', title: 'The engine, layer by layer.' },
  { id: 'testing', n: '05', name: 'How we test', tag: 'correctness', title: 'Bug-class coverage, not test count.' },
  { id: 'benchmarks', n: '06', name: 'Benchmarks', tag: 'the numbers', title: 'The numbers.' },
  { id: 'why', n: '07', name: 'Why it matters', tag: 'the transfer', title: 'Systems facts with product consequences.' },
];
---

<PitchLayout title="Strata — engine internals" sections={sections}>
  <!-- §1 · WHAT IT IS -->
  <section id="what-it-is" class="pitch-section" aria-label="What Strata is">
    <div class="pitch-wrap">
      <header class="sec-header reveal">
        <span class="sec-id"><span class="sec-hash">§</span>&thinsp;01<span class="sec-name">What it is</span></span>
        <span class="sec-tag">the substrate</span>
      </header>

      <div class="sec-body">
        <div class="open-grid">
          <div class="open-statement reveal">
            <h1 class="open-product">Strata is an embedded database for AI&nbsp;agents.</h1>
            <p class="open-technical">A branch-aware, MVCC, log-structured key-value store — KV, JSON, events, vectors, and graph as capabilities over one&nbsp;substrate.</p>
          </div>

          <aside class="substrate reveal" style="transition-delay: 110ms" aria-label="One substrate">
            <div class="substrate-body">
              <p class="substrate-tag">capabilities</p>
              <div class="cap-row">
                <span class="cap" style="--hue: var(--color-strata-kv)">KV</span>
                <span class="cap" style="--hue: var(--color-strata-json)">JSON</span>
                <span class="cap" style="--hue: var(--color-strata-event)">Event</span>
                <span class="cap" style="--hue: var(--color-strata-vector)">Vector</span>
                <span class="cap" style="--hue: var(--color-strata-graph)">Graph</span>
              </div>
              <p class="substrate-over">over one substrate</p>
              <div class="base">
                <span class="base-name">branch-aware · MVCC · LSM</span>
                <div class="lsm" aria-hidden="true">
                  <div class="lsm-row"><span class="lsm-lab">mem</span><span class="lsm-bar lsm-hot" style="width: 26%"></span></div>
                  <div class="lsm-row"><span class="lsm-lab">L0</span><span class="lsm-bar" style="width: 46%"></span></div>
                  <div class="lsm-row"><span class="lsm-lab">L1</span><span class="lsm-bar" style="width: 70%"></span></div>
                  <div class="lsm-row"><span class="lsm-lab">L2</span><span class="lsm-bar" style="width: 96%"></span></div>
                </div>
              </div>
            </div>
          </aside>
        </div>
      </div>
    </div>
  </section>

  <!-- §2 · WHERE IT FITS -->
  <section id="where-it-fits" class="pitch-section" aria-label="Where Strata fits">
    <div class="pitch-wrap">
      <header class="sec-header reveal">
        <span class="sec-id"><span class="sec-hash">§</span>&thinsp;02<span class="sec-name">Where it fits</span></span>
        <span class="sec-tag">the lineage</span>
      </header>

      <div class="sec-body">
        <h2 class="sec-title reveal">Every era gets an embedded database.</h2>
        <p class="sec-lead reveal" style="transition-delay: 60ms">
          Every era of computing creates a new database class — each in two forms, server and embedded.
        </p>

        <div class="data-panel reveal" style="transition-delay: 110ms">
          <table class="lineage">
            <thead>
              <tr>
                <th scope="col" class="c-era">Era</th>
                <th scope="col">Server</th>
                <th scope="col" class="c-emb">Embedded</th>
              </tr>
            </thead>
            <tbody>
              <tr><th scope="row">Relational</th><td>Oracle · Postgres</td><td class="emb">SQLite</td></tr>
              <tr><th scope="row">Analytics</th><td>Snowflake · BigQuery</td><td class="emb">DuckDB</td></tr>
              <tr><th scope="row">Vector</th><td>Pinecone</td><td class="emb">LanceDB · Chroma</td></tr>
              <tr class="row-agent"><th scope="row">Agent state</th><td class="twin">Redis</td><td class="emb strata">Strata</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- §3–§7 · placeholders -->
  {
    pending.map((s) => (
      <section id={s.id} class="pitch-section">
        <div class="pitch-wrap">
          <header class="sec-header">
            <span class="sec-id"><span class="sec-hash">§</span>&thinsp;{s.n}<span class="sec-name">{s.name}</span></span>
            <span class="sec-tag">{s.tag}</span>
          </header>
          <div class="sec-body">
            <h2 class="sec-title pending-title">{s.title}</h2>
            <span class="pending-tag">building next</span>
          </div>
        </div>
      </section>
    ))
  }

  <style>
    /* ===== section frame : a ruled spec-sheet page ===================== */
    .pitch-section {
      min-height: 100vh;
      display: flex;
      padding-block: 2.4rem 3rem;
      border-bottom: 1px solid var(--color-line);
    }
    .pitch-section:last-child {
      border-bottom: none;
    }
    .pitch-wrap {
      flex: 1;
      display: flex;
      flex-direction: column;
      width: 100%;
      max-width: 78rem;
      margin-inline: auto;
      padding-inline: 3rem;
    }
    @media (max-width: 900px) {
      .pitch-section {
        padding-block: 2rem;
      }
      .pitch-wrap {
        padding-inline: 1.4rem;
      }
    }

    .sec-header {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 1rem;
      padding-bottom: 0.85rem;
      border-bottom: 1px solid var(--color-line-hover);
    }
    .sec-id {
      display: inline-flex;
      align-items: baseline;
      font-family: var(--font-mono);
      font-size: 0.82rem;
      letter-spacing: 0.02em;
      color: var(--color-ink-hi);
    }
    .sec-hash {
      color: var(--ember);
    }
    .sec-name {
      margin-left: 0.7rem;
      font-size: 0.72rem;
      letter-spacing: 0.13em;
      text-transform: uppercase;
      color: var(--color-ink-mid);
    }
    .sec-tag {
      font-family: var(--font-mono);
      font-size: 0.7rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--color-ink-low);
    }

    .sec-body {
      flex: 1;
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding-block: 2.5rem 0;
    }

    .sec-title {
      font-size: clamp(1.85rem, 1.3rem + 1.5vw, 2.6rem);
      line-height: 1.1;
      letter-spacing: -0.022em;
      font-weight: 600;
      color: var(--color-ink-hi);
      text-wrap: balance;
    }
    .sec-lead {
      margin-top: 1rem;
      max-width: 46rem;
      font-size: var(--text-body-lg);
      line-height: 1.5;
      color: var(--color-ink-mid);
      text-wrap: pretty;
    }

    /* ===== §1 · fused statement + datasheet spec panel ================= */
    .open-grid {
      display: grid;
      grid-template-columns: minmax(0, 1.35fr) minmax(22rem, 1fr);
      gap: 3.5rem;
      align-items: center;
    }
    @media (max-width: 880px) {
      .open-grid {
        grid-template-columns: 1fr;
        gap: 2.5rem;
      }
    }
    .open-product {
      font-size: clamp(2rem, 1.2rem + 2.2vw, 3.2rem);
      line-height: 1.12;
      letter-spacing: -0.027em;
      font-weight: 600;
      color: var(--color-ink-hi);
      text-wrap: balance;
    }
    .open-technical {
      margin-top: 1.4rem;
      max-width: 40rem;
      font-size: clamp(1.1rem, 1rem + 0.55vw, 1.45rem);
      line-height: 1.5;
      color: var(--color-ink-mid);
      text-wrap: pretty;
    }

    .substrate {
      border: 1px solid var(--color-line);
      border-radius: var(--radius-card);
      background: var(--color-panel);
      box-shadow: var(--shadow-panel);
      overflow: hidden;
    }
    .substrate-body {
      padding: 1.5rem 1.5rem 1.6rem;
    }
    .substrate-tag,
    .substrate-over {
      font-family: var(--font-mono);
      font-size: 0.66rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--color-ink-low);
    }
    .substrate-tag {
      margin: 0 0 0.7rem;
    }
    .cap-row {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 0.4rem;
    }
    .cap {
      padding: 0.5rem 0.3rem;
      text-align: center;
      border: 1px solid color-mix(in srgb, var(--hue) 34%, transparent);
      border-radius: var(--radius-control);
      background: color-mix(in srgb, var(--hue) 10%, var(--color-panel));
      color: var(--hue);
      font-family: var(--font-mono);
      font-size: 0.78rem;
      letter-spacing: 0.01em;
    }
    .substrate-over {
      margin: 1.15rem 0 0.85rem;
      text-align: center;
    }
    .base {
      padding: 1.2rem 1.3rem 1.3rem;
      border: 1px solid var(--color-line-hover);
      border-radius: var(--radius-control);
      background: color-mix(in srgb, var(--color-ink-hi) 3.5%, var(--color-panel));
    }
    .base-name {
      display: block;
      text-align: center;
      font-family: var(--font-mono);
      font-size: 0.84rem;
      letter-spacing: 0.03em;
      color: var(--color-ink-hi);
    }
    .lsm {
      margin-top: 1.05rem;
      display: flex;
      flex-direction: column;
      gap: 0.42rem;
    }
    .lsm-row {
      display: grid;
      grid-template-columns: 2.1rem 1fr;
      align-items: center;
      gap: 0.6rem;
    }
    .lsm-lab {
      font-family: var(--font-mono);
      font-size: 0.62rem;
      letter-spacing: 0.04em;
      color: var(--color-ink-low);
      text-align: right;
    }
    .lsm-bar {
      height: 0.72rem;
      border-radius: 2px;
      background: color-mix(in srgb, var(--color-ink-hi) 22%, transparent);
    }
    .lsm-hot {
      background: var(--ember);
    }

    /* ===== §2 · lineage data panel ==================================== */
    .data-panel {
      margin-top: 2.25rem;
      max-width: 62rem;
      border: 1px solid var(--color-line);
      border-radius: var(--radius-card);
      background: var(--color-panel);
      box-shadow: var(--shadow-panel);
      overflow: hidden;
    }
    .lineage {
      width: 100%;
      border-collapse: collapse;
      font-variant-numeric: tabular-nums;
    }
    .lineage th,
    .lineage td {
      text-align: left;
      padding: 0.95rem 1.4rem;
      border-bottom: 1px solid var(--color-line);
      font-size: 1.02rem;
    }
    .lineage thead th {
      font-family: var(--font-mono);
      font-size: 0.66rem;
      font-weight: 500;
      letter-spacing: 0.13em;
      text-transform: uppercase;
      color: var(--color-ink-low);
      padding-block: 0.78rem;
      background: color-mix(in srgb, var(--color-ink-hi) 2.5%, var(--color-panel));
    }
    .lineage tbody th {
      font-weight: 500;
      color: var(--color-ink-mid);
    }
    .lineage td {
      color: var(--color-ink-mid);
    }
    .lineage .c-emb,
    .lineage td.emb {
      border-left: 1px solid var(--color-line);
      background: color-mix(in srgb, var(--color-ink-hi) 2%, var(--color-panel));
      color: var(--color-ink-hi);
      font-weight: 500;
    }
    .lineage tbody tr:last-child th,
    .lineage tbody tr:last-child td {
      border-bottom: none;
    }
    .row-agent th,
    .lineage .twin {
      color: var(--color-ink-hi);
      font-weight: 600;
    }
    .lineage td.strata {
      background: var(--ember-soft);
      border-left-color: color-mix(in srgb, var(--color-terracotta-500) 45%, transparent);
      color: var(--color-terracotta-700);
      font-weight: 700;
    }
    .sec-note {
      margin-top: 1.6rem;
      max-width: 54rem;
      font-size: var(--text-small);
      line-height: 1.6;
      color: var(--color-ink-low);
    }
    .sec-note strong {
      color: var(--color-terracotta-700);
      font-weight: 600;
    }
    @media (max-width: 640px) {
      .lineage th,
      .lineage td {
        padding: 0.7rem 0.85rem;
        font-size: 0.92rem;
      }
    }

    /* ===== placeholders =============================================== */
    .pending-title {
      color: var(--color-ink-mid);
      max-width: 24ch;
    }
    .pending-tag {
      display: inline-block;
      margin-top: 1.4rem;
      padding: 0.25rem 0.7rem;
      border: 1px dashed var(--color-line-hover);
      border-radius: 999px;
      font-family: var(--font-mono);
      font-size: 0.66rem;
      letter-spacing: 0.06em;
      color: var(--color-ink-low);
    }
  </style>
</PitchLayout>
