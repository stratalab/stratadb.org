                  <text x="34" y="82" style="font-family:var(--font-mono);font-size:8.5px;fill:var(--color-ink-mid)">tables/&lt;branch&gt;/l0000/&lt;id&gt;</text>
                  <rect x="24" y="92" width="216" height="20" rx="2.5" style="fill:var(--color-panel);stroke:var(--color-ink-mid);stroke-width:1.1" />
                  <text x="34" y="106" style="font-family:var(--font-mono);font-size:8.5px;fill:var(--color-ink-mid)">snapshots/9c1d2b7a…</text>
                  <rect x="24" y="116" width="216" height="20" rx="2.5" style="fill:var(--color-panel);stroke:var(--color-ink-mid);stroke-width:1.1" />
                  <text x="34" y="130" style="font-family:var(--font-mono);font-size:8px;fill:var(--color-ink-mid)">quarantine/&lt;branch&gt;/&lt;id&gt; · locks/writer</text>
