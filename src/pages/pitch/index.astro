      color: var(--color-ink-mid);
    }
    .lsm-runs {
      display: flex;
      gap: 0.3rem;
      width: 100%;
    }
    .lsm-run {
      flex: 1;
      height: 1.2rem;
      display: flex;
      align-items: center;
      justify-content: center;
      border: 1px solid var(--color-ink-mid);
      border-radius: 3px;
      background: var(--color-panel);
      font-family: var(--font-mono);
      font-size: 0.62rem;
      color: var(--color-ink-mid);
    }
    .lsm-level.is-hit .lsm-run {
      border-color: var(--ember);
      background: var(--ember-soft);
      color: var(--color-terracotta-700);
    }
    .lsm-base {
      height: 0.95rem;
      border-radius: 3px;
      background: color-mix(in srgb, var(--color-ink-hi) 8%, var(--color-panel));
      border: 1px solid var(--color-line-hover);
    }
    .lsm-flow {
      display: flex;
      align-items: center;
      gap: 0.7rem;
      padding-left: 2.7rem;
      min-height: 0.95rem;
      font-family: var(--font-mono);
      font-size: 0.6rem;
      color: var(--color-ink-low);
      transition: color var(--dur-2) var(--ease-out);
    }
    .lsm-flow em {
      font-style: normal;
      color: var(--color-ink-low);
      opacity: 0.7;
    }
    .lsm-flow.is-active,
    .lsm-flow.is-active em {
      color: var(--ember);
      opacity: 1;
    }
    .lsm-read {
      position: absolute;
      top: 0.5rem;
      right: 0.6rem;
      padding: 0.1rem 0.5rem;
      border: 1px solid color-mix(in srgb, var(--ember) 40%, transparent);
      border-radius: 999px;
      background: var(--ember-soft);
      font-family: var(--font-mono);
      font-size: 0.62rem;
      color: var(--color-terracotta-700);
    }
    .lsm-read[hidden] {
      display: none;
    }
    .lsm-stage.is-reading [data-lsm-memmeta] {
      visibility: hidden;
    }
    .lsm-note {
      margin-top: 0.7rem;
      min-height: 2.55rem;
      font-family: var(--font-mono);
      font-size: 0.72rem;
      line-height: 1.5;
      color: var(--color-ink-mid);
      text-wrap: pretty;
    }
    .lsm-controls {
      display: flex;
      align-items: center;
      gap: 0.4rem;
    }
    .lsm-btn {
      padding: 0.32rem 0.62rem;
      border: 1px solid var(--color-line-hover);
      border-radius: var(--radius-control);
      background: var(--color-panel);
      font-family: var(--font-mono);
      font-size: 0.7rem;
      color: var(--color-ink-mid);
      cursor: pointer;
      transition: border-color var(--dur-2) var(--ease-out), color var(--dur-2) var(--ease-out);
    }
    .lsm-btn:hover {
      border-color: var(--color-ink-mid);
      color: var(--color-ink-hi);
    }
    .lsm-btn-primary {
      border-color: color-mix(in srgb, var(--ember) 45%, transparent);
      background: var(--ember-soft);
      color: var(--color-terracotta-700);
    }
    .lsm-btn-primary:hover {
      border-color: var(--ember);
      color: var(--color-terracotta-700);
    }
    .lsm-btn:disabled {
      opacity: 0.4;
      cursor: default;
    }
    .lsm-count {
      margin-left: auto;
      font-family: var(--font-mono);
      font-size: 0.66rem;
      color: var(--color-ink-low);
    }
    @keyframes lsm-in {
      from {
        opacity: 0;
        transform: translateY(-3px);
      }
      to {
        opacity: 1;
        transform: none;
      }
    }
    @keyframes lsm-pulse {
      0%, 100% {
        box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--ember) 55%, transparent);
      }
      50% {
        box-shadow: inset 0 0 0 2px var(--ember);
      }
    }
    @media (prefers-reduced-motion: no-preference) {
      .lsm-in {
        animation: lsm-in 0.26s var(--ease-out) both;
      }
      .lsm-level.is-probing {
        animation: lsm-pulse 0.62s var(--ease-out);
      }
    }

    /* ===== §4 · L6 branch-fork interactive =========================== */
    .bf {
      margin-top: 1.1rem;
    }
    .bf-stage {
      display: flex;
      flex-direction: column;
      gap: 0.36rem;
      padding: 0.6rem 1rem 0.68rem;
      border: 1px solid var(--color-line);
      border-radius: var(--radius-card);
      background: color-mix(in srgb, var(--color-ink-hi) 1.5%, var(--color-panel));
    }
    .bf-key {
      font-family: var(--font-mono);
      font-size: 0.62rem;
      letter-spacing: 0.04em;
      color: var(--color-ink-low);
    }
    .bf-key b {
      color: var(--color-ink-hi);
      font-weight: 600;
    }
    .bf-heads,
    .bf-reads {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.8rem;
    }
    .bf-head {
      display: flex;
      flex-direction: column;
      gap: 0.3rem;
    }
    .bf-head-label {
      font-family: var(--font-mono);
      font-size: 0.7rem;
      font-weight: 600;
      color: var(--color-ink-hi);
    }
    .bf-cells {
      display: flex;
      flex-direction: column;
      gap: 0.26rem;
    }
    .bf-cell {
      display: grid;
      grid-template-columns: 2.1rem 1fr;
      align-items: center;
      gap: 0.5rem;
      height: 1.25rem;
      padding: 0 0.55rem;
      border: 1px solid var(--color-ink-mid);
      border-radius: 3px;
      background: var(--color-panel);
      font-family: var(--font-mono);
    }
    .bf-cell .bf-v {
      font-size: 0.58rem;
      color: var(--color-ink-low);
    }
    .bf-cell .bf-val {
      font-size: 0.66rem;
      color: var(--color-ink-hi);
    }
    .bf-cell.is-inherited {
      border-style: dashed;
      border-color: var(--color-line-hover);
      background: transparent;
    }
    .bf-cell.is-inherited .bf-val {
      color: var(--color-ink-mid);
    }
    .bf-cell.is-hot {
      border-style: solid;
      border-color: var(--ember);
      background: var(--ember-soft);
    }
    .bf-cell.is-hot .bf-v {
      color: var(--ember);
    }
    .bf-cell.is-hot .bf-val {
      color: var(--color-terracotta-700);
      font-weight: 600;
    }
    .bf-ghost {
      display: flex;
      align-items: center;
      height: 1.25rem;
      padding: 0 0.55rem;
      border: 1px dashed var(--color-line-hover);
      border-radius: 3px;
      font-family: var(--font-mono);
      font-size: 0.62rem;
      color: var(--color-ink-low);
    }
    .bf-gate {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.05rem 0;
      font-family: var(--font-mono);
      font-size: 0.62rem;
      color: var(--ember);
    }
    .bf-gate::before,
    .bf-gate::after {
      content: '';
      flex: 1;
      border-top: 1px dashed var(--ember);
    }
    .bf-gate[hidden] {
      display: none;
    }
    .bf-base {
      display: flex;
      flex-direction: column;
      gap: 0.3rem;
    }
    .bf-base-label {
      font-family: var(--font-mono);
      font-size: 0.6rem;
      letter-spacing: 0.04em;
      color: var(--color-ink-low);
    }
    .bf-read {
      font-family: var(--font-mono);
      font-size: 0.66rem;
      color: var(--color-ink-mid);
    }
    .bf-read b {
      color: var(--color-terracotta-700);
      font-weight: 600;
    }
    .bf-read[hidden] {
      display: none;
    }
    @media (prefers-reduced-motion: no-preference) {
      .bf-cell.lsm-in {
        animation: lsm-in 0.26s var(--ease-out) both;
      }
    }

    /* ===== placeholders =============================================== */
    .pending-title {
      color: var(--color-ink-mid);
      max-width: 24ch;
    }
    .pending-tag {
      display: inline-block;
      margin-top: 1.4rem;
      padding: 0.25rem 0.7rem;
      border: 1px dashed var(--color-line-hover);
      border-radius: 999px;
      font-family: var(--font-mono);
      font-size: 0.66rem;
      letter-spacing: 0.06em;
      color: var(--color-ink-low);
    }
  </style>

  <script>
    // §4 storage explorer — select a layer, swap its detail pane.
    const explorer = document.querySelector('.explorer');
    if (explorer) {
      const nodes = explorer.querySelectorAll<HTMLElement>('[data-node]');
      const panes = explorer.querySelectorAll<HTMLElement>('[data-pane]');
      const select = (key: string | undefined) => {
        if (!key) return;
        nodes.forEach((n) => n.classList.toggle('is-active', n.dataset.node === key));
        panes.forEach((p) => p.classList.toggle('is-active', p.dataset.pane === key));
      };
      nodes.forEach((n) => n.addEventListener('click', () => select(n.dataset.node)));
    }

    // §4 · L5 living-LSM — deterministic, precomputed frames: write → flush → compaction → read.
    interface LsmFrame {
      mem: string[];
      l0: string[];
      l1: string[];
      note: string;
      active?: 'mem' | 'l0' | 'l1';
      flow?: 'flush' | 'compact';
      read?: string;
      probe?: 'mem' | 'l0' | 'l1';
      hit?: 'mem' | 'l0' | 'l1';
    }
    const lsm = document.querySelector<HTMLElement>('[data-lsm]');
    if (lsm) {
      const F: LsmFrame[] = [
        { mem: [], l0: [], l1: [], note: 'An LSM batches writes in memory, then flushes sorted tables to disk. Step ▸ to follow one through.' },
        { mem: ['a'], l0: [], l1: [], active: 'mem', note: 'write a → memtable — held in memory, kept sorted.' },
        { mem: ['a', 'b'], l0: [], l1: [], active: 'mem', note: 'write b → memtable. No disk seek yet; writes stay sequential.' },
        { mem: ['a', 'b', 'c'], l0: [], l1: [], active: 'mem', note: 'write c → the memtable is full (3 / 3).' },
        { mem: [], l0: ['a–c'], l1: [], active: 'l0', flow: 'flush', note: 'flush → one immutable L0 table, written in one sequential pass. The memtable clears.' },
        { mem: ['d', 'e', 'f'], l0: ['a–c'], l1: [], active: 'mem', note: 'more writes fill the next memtable.' },
        { mem: [], l0: ['a–c', 'd–f'], l1: [], active: 'l0', flow: 'flush', note: 'flush → a second L0 table.' },
        { mem: [], l0: ['a–c', 'd–f', 'a–e'], l1: [], active: 'l0', flow: 'flush', note: 'a third flush — L0 tables may overlap in key range (a–c, d–f, a–e), so a read may touch several.' },
        { mem: [], l0: [], l1: ['a–f'], active: 'l1', flow: 'compact', note: 'L0 reaches its threshold, so compaction merges all three into one sorted, non-overlapping L1 run. The caller supplies the prune / tombstone / TTL policy that the compaction applies.' },
        { mem: ['g', 'h', 'i'], l0: [], l1: ['a–f'], active: 'mem', note: 'writes keep landing in memory, on top of the merged level.' },
        { mem: [], l0: ['g–i'], l1: ['a–f'], active: 'l0', flow: 'flush', note: 'flush → a fresh L0 table now sits above the L1 run.' },
        { mem: ['k'], l0: ['g–i'], l1: ['a–f'], active: 'mem', note: 'one more write waits in the memtable.' },
        { mem: ['k'], l0: ['g–i'], l1: ['a–f'], read: 'b', probe: 'mem', note: 'read b → check the memtable first… not here.' },
        { mem: ['k'], l0: ['g–i'], l1: ['a–f'], read: 'b', probe: 'l0', note: '…then L0, newest table first… b is not in g–i.' },
        { mem: ['k'], l0: ['g–i'], l1: ['a–f'], read: 'b', probe: 'l1', hit: 'l1', note: '…then L1 → found. The search stops at the first match and returns the newest version of b.' },
      ];

      const elStage = lsm.querySelector<HTMLElement>('.lsm-stage')!;
      // Scoped-CSS bridge: stamp Astro's component scope attribute onto JS-built
      // elements so the scoped .lsm-chip / .lsm-tile / .lsm-run rules match them.
      const scopeAttr = Array.from(elStage.attributes).map((a) => a.name).find((n) => n.startsWith('data-astro-cid-')) ?? '';
      const elMem = lsm.querySelector<HTMLElement>('[data-lsm-mem]')!;
      const elMemMeta = lsm.querySelector<HTMLElement>('[data-lsm-memmeta]')!;
      const elL0 = lsm.querySelector<HTMLElement>('[data-lsm-l0]')!;
      const elL1 = lsm.querySelector<HTMLElement>('[data-lsm-l1]')!;
      const elNote = lsm.querySelector<HTMLElement>('[data-lsm-note]')!;
      const elCount = lsm.querySelector<HTMLElement>('[data-lsm-count]')!;
      const elRead = lsm.querySelector<HTMLElement>('[data-lsm-read]')!;
      const btnNext = lsm.querySelector<HTMLButtonElement>('[data-lsm-next]')!;
      const btnPrev = lsm.querySelector<HTMLButtonElement>('[data-lsm-prev]')!;
      const btnReset = lsm.querySelector<HTMLButtonElement>('[data-lsm-reset]')!;
      const btnPlay = lsm.querySelector<HTMLButtonElement>('[data-lsm-play]')!;
      const levels: Record<string, HTMLElement> = {};
      lsm.querySelectorAll<HTMLElement>('[data-lsm-level]').forEach((l) => { levels[l.dataset.lsmLevel!] = l; });
      const flows: Record<string, HTMLElement> = {};
      lsm.querySelectorAll<HTMLElement>('[data-lsm-flow]').forEach((f) => { flows[f.dataset.lsmFlow!] = f; });

      let i = 0;
      let timer: ReturnType<typeof setInterval> | null = null;

      const render = () => {
        const f = F[i];
        let mem = '';
        for (let s = 0; s < 3; s++) {
          mem += f.mem[s]
            ? `<span class="lsm-chip${f.active === 'mem' && s === f.mem.length - 1 ? ' lsm-in' : ''}" ${scopeAttr}>${f.mem[s]}</span>`
            : `<span class="lsm-slot" ${scopeAttr}></span>`;
        }
        elMem.innerHTML = mem;
        elMemMeta.textContent = `${f.mem.length} / 3`;
        elL0.innerHTML = f.l0
          .map((r, idx) => `<span class="lsm-tile${f.active === 'l0' && idx === f.l0.length - 1 ? ' lsm-in' : ''}" ${scopeAttr}>${r}</span>`)
          .join('');
        elL1.innerHTML = f.l1
          .map((r) => `<span class="lsm-run${f.active === 'l1' ? ' lsm-in' : ''}" ${scopeAttr}>${r} · sorted</span>`)
          .join('');
        elNote.textContent = f.note;
        elCount.textContent = `${String(i).padStart(2, '0')} / ${String(F.length - 1).padStart(2, '0')}`;
        for (const key of Object.keys(levels)) {
          levels[key].classList.toggle('is-active', f.active === key && !f.read);
          levels[key].classList.toggle('is-probing', f.probe === key);
          levels[key].classList.toggle('is-hit', f.hit === key);
        }
        for (const key of Object.keys(flows)) {
          flows[key].classList.toggle('is-active', f.flow === key);
        }
        if (f.read) {
          elRead.textContent = `read ${f.read}`;
          elRead.hidden = false;
        } else {
          elRead.hidden = true;
        }
        elStage.classList.toggle('is-reading', !!f.read);
        btnPrev.disabled = i === 0;
        btnNext.disabled = i === F.length - 1;
      };

      const go = (n: number) => { i = Math.max(0, Math.min(F.length - 1, n)); render(); };
      const stopPlay = () => {
        if (timer) { clearInterval(timer); timer = null; }
        btnPlay.textContent = 'play';
      };
      btnNext.addEventListener('click', () => { stopPlay(); go(i + 1); });
      btnPrev.addEventListener('click', () => { stopPlay(); go(i - 1); });
      btnReset.addEventListener('click', () => { stopPlay(); go(0); });
      btnPlay.addEventListener('click', () => {
        if (timer) { stopPlay(); return; }
        if (i === F.length - 1) go(0);
        btnPlay.textContent = 'pause';
        timer = setInterval(() => {
          if (i >= F.length - 1) { stopPlay(); return; }
          go(i + 1);
        }, 1150);
      });

      render();
    }

    // §4 · L6 branch-fork — fork (O(metadata)) → write each branch → one key's reads diverge.
    interface BfCell {
      v: string;
      val: string;
    }
    interface BfFrame {
      fork: boolean;
      baseLabel: string;
      mainHead: BfCell[];
      forkHead: BfCell[];
      base: BfCell[];
      hot: Record<string, string>;
      readMain: string;
      readFork: string | null;
      readForkAs?: string;
      note: string;
    }
    const bf = document.querySelector<HTMLElement>('[data-bf]');
    if (bf) {
      const BASE: BfCell[] = [{ v: 'v5', val: 'c' }, { v: 'v3', val: 'b' }, { v: 'v1', val: 'a' }];
      const BF: BfFrame[] = [
        { fork: false, baseLabel: 'main · versions of k', mainHead: [], forkHead: [], base: BASE,
          hot: { v5: 'main' }, readMain: 'c', readFork: null,
          note: 'main holds one key k with three versions — v1, v3, v5 — newest first. A read returns the newest: c.' },
        { fork: true, baseLabel: 'shared base · inherited by reference', mainHead: [], forkHead: [], base: BASE,
          hot: { v5: 'both' }, readMain: 'c', readFork: 'c',
          note: 'Fork main. O(metadata) — zero rows copied; the fork inherits main’s layers by reference, gated at v5. Both branches read c.' },
        { fork: true, baseLabel: 'shared base · inherited by reference', mainHead: [], forkHead: [{ v: 'v6', val: 'x' }], base: BASE,
          hot: { v6: 'fork', v5: 'main' }, readMain: 'c', readFork: 'x',
          note: 'Write k=x on the fork. It lands in the fork’s own layer (v6) and shadows the inherited base. The fork now reads x; main still reads c.' },
        { fork: true, baseLabel: 'shared base · inherited by reference', mainHead: [{ v: 'v7', val: 'y' }], forkHead: [{ v: 'v6', val: 'x' }], base: BASE,
          hot: { v7: 'main', v6: 'fork' }, readMain: 'y', readFork: 'x',
          note: 'Write k=y on main (v7). The fork’s gate stays pinned at v5, so it never sees v7. The same key now reads y on main and x on the fork, from one shared base.' },
        { fork: true, baseLabel: 'shared base · inherited by reference', mainHead: [{ v: 'v7', val: 'y' }], forkHead: [{ v: 'v6', val: 'x' }], base: BASE,
          hot: { v7: 'main', v3: 'fork' }, readMain: 'y', readFork: 'b', readForkAs: '@ v3',
          note: 'An as-of read works on the fork too: reading k as-of v3 returns b, found by walking the inherited chain. The same newest-first ordering serves latest, as-of, and history reads.' },
      ];

      const bfStage = bf.querySelector<HTMLElement>('.bf-stage')!;
      const bfScope = Array.from(bfStage.attributes).map((a) => a.name).find((n) => n.startsWith('data-astro-cid-')) ?? '';
      const elMainHead = bf.querySelector<HTMLElement>('[data-bf-mainhead]')!;
      const elForkHead = bf.querySelector<HTMLElement>('[data-bf-forkhead]')!;
      const elGate = bf.querySelector<HTMLElement>('[data-bf-gate]')!;
      const elBaseLabel = bf.querySelector<HTMLElement>('[data-bf-baselabel]')!;
      const elBase = bf.querySelector<HTMLElement>('[data-bf-base]')!;
      const elReadMain = bf.querySelector<HTMLElement>('[data-bf-readmain]')!;
      const elReadFork = bf.querySelector<HTMLElement>('[data-bf-readfork]')!;
      const elNote = bf.querySelector<HTMLElement>('[data-bf-note]')!;
      const elCount = bf.querySelector<HTMLElement>('[data-bf-count]')!;
      const btnNext = bf.querySelector<HTMLButtonElement>('[data-bf-next]')!;
      const btnPrev = bf.querySelector<HTMLButtonElement>('[data-bf-prev]')!;
      const btnReset = bf.querySelector<HTMLButtonElement>('[data-bf-reset]')!;
      const btnPlay = bf.querySelector<HTMLButtonElement>('[data-bf-play]')!;

      let bi = 0;
      let bfTimer: ReturnType<typeof setInterval> | null = null;

      const cellInner = (c: BfCell) => `<span class="bf-v" ${bfScope}>${c.v}</span><span class="bf-val" ${bfScope}>${c.val}</span>`;
      const ownCell = (c: BfCell, hot: boolean) =>
        `<div class="bf-cell${hot ? ' is-hot' : ''} lsm-in" ${bfScope}>${cellInner(c)}</div>`;
      const baseCell = (c: BfCell, hot: boolean, inherited: boolean) =>
        `<div class="bf-cell${inherited ? ' is-inherited' : ''}${hot ? ' is-hot' : ''}" ${bfScope}>${cellInner(c)}</div>`;
      const ghost = (t: string) => `<div class="bf-ghost" ${bfScope}>${t}</div>`;

      const renderBf = () => {
        const f = BF[bi];
        elMainHead.innerHTML = f.mainHead.length
          ? f.mainHead.map((c) => ownCell(c, !!f.hot[c.v])).join('')
          : ghost('latest in base ↓');
        elForkHead.innerHTML = !f.fork
          ? ghost('— not forked —')
          : f.forkHead.length
            ? f.forkHead.map((c) => ownCell(c, !!f.hot[c.v])).join('')
            : ghost('inherits base ↓');
        elGate.hidden = !f.fork;
        elBaseLabel.textContent = f.baseLabel;
        elBase.innerHTML = f.base.map((c) => baseCell(c, !!f.hot[c.v], f.fork)).join('');
        elReadMain.innerHTML = `main reads k = <b ${bfScope}>${f.readMain}</b>`;
        if (f.readFork == null) {
          elReadFork.hidden = true;
        } else {
          elReadFork.hidden = false;
          elReadFork.innerHTML = `fork${f.readForkAs ? ' ' + f.readForkAs : ''} reads k = <b ${bfScope}>${f.readFork}</b>`;
        }
        elNote.textContent = f.note;
        elCount.textContent = `${bi} / ${BF.length - 1}`;
        btnPrev.disabled = bi === 0;
        btnNext.disabled = bi === BF.length - 1;
      };

      const goBf = (n: number) => { bi = Math.max(0, Math.min(BF.length - 1, n)); renderBf(); };
      const stopBfPlay = () => {
        if (bfTimer) { clearInterval(bfTimer); bfTimer = null; }
        btnPlay.textContent = 'play';
      };
      btnNext.addEventListener('click', () => { stopBfPlay(); goBf(bi + 1); });
      btnPrev.addEventListener('click', () => { stopBfPlay(); goBf(bi - 1); });
      btnReset.addEventListener('click', () => { stopBfPlay(); goBf(0); });
      btnPlay.addEventListener('click', () => {
        if (bfTimer) { stopBfPlay(); return; }
        if (bi === BF.length - 1) goBf(0);
        btnPlay.textContent = 'pause';
        bfTimer = setInterval(() => {
          if (bi >= BF.length - 1) { stopBfPlay(); return; }
          goBf(bi + 1);
        }, 1400);
      });

      renderBf();
    }
  </script>
</PitchLayout>
