      border-radius: 999px;
    }
    .pane-name {
      font-size: 1.3rem;
      font-weight: 600;
      letter-spacing: -0.015em;
      color: var(--color-ink-hi);
    }
    .pane-desc {
      margin-top: 0.7rem;
      max-width: 44rem;
      font-size: 0.94rem;
      line-height: 1.6;
      color: var(--color-ink-mid);
    }
    .pane-svg {
      margin: 1.15rem 0 0;
      padding: 0.6rem 0.9rem;
      border: 1px solid var(--color-line);
      border-radius: var(--radius-card);
      background: color-mix(in srgb, var(--color-ink-hi) 1.5%, var(--color-panel));
    }
    .pane-svg svg {
      display: block;
      width: 100%;
      height: auto;
      max-height: 11rem;
    }
    .pane-show {
      margin-top: 1rem;
      font-family: var(--font-mono);
      font-size: 0.74rem;
      line-height: 1.5;
      color: var(--color-ink-low);
      text-wrap: pretty;
    }
    .pane-show-k {
      color: var(--ember);
      margin-right: 0.5rem;
    }

    /* ===== §4 · L5 living-LSM interactive ============================ */
    .lsm {
      margin-top: 1.1rem;
    }
    .lsm-stage {
      position: relative;
      display: flex;
      flex-direction: column;
      gap: 0.28rem;
      padding: 0.85rem 1rem 0.95rem;
      border: 1px solid var(--color-line);
      border-radius: var(--radius-card);
      background: color-mix(in srgb, var(--color-ink-hi) 1.5%, var(--color-panel));
    }
    .lsm-level {
      display: grid;
      grid-template-columns: 2.1rem 1fr 5.4rem;
      align-items: center;
      gap: 0.6rem;
      padding: 0.34rem 0.4rem;
      border-radius: var(--radius-control);
      transition: box-shadow var(--dur-2) var(--ease-out), background var(--dur-2) var(--ease-out);
    }
    .lsm-level.is-active {
      background: color-mix(in srgb, var(--ember) 7%, transparent);
      box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--ember) 38%, transparent);
    }
    .lsm-level.is-probing {
      box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--ember) 55%, transparent);
    }
    .lsm-tag {
      font-family: var(--font-mono);
      font-size: 0.64rem;
      letter-spacing: 0.04em;
      color: var(--color-ink-low);
    }
    .lsm-meta {
      font-family: var(--font-mono);
      font-size: 0.6rem;
      color: var(--color-ink-low);
      text-align: right;
    }
    .lsm-slots {
      display: flex;
      gap: 0.3rem;
    }
    .lsm-slot,
    .lsm-chip {
      width: 2.7rem;
      height: 1.15rem;
      border-radius: 3px;
    }
    .lsm-slot {
      border: 1px dashed var(--color-line-hover);
    }
    .lsm-chip {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border: 1px solid color-mix(in srgb, var(--ember) 45%, transparent);
      background: var(--ember-soft);
      font-family: var(--font-mono);
      font-size: 0.66rem;
      color: var(--color-terracotta-700);
    }
    .lsm-tiles {
      display: flex;
      gap: 0.35rem;
    }
    .lsm-tile {
      min-width: 3.2rem;
      height: 1.25rem;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 0 0.45rem;
      border: 1px solid var(--color-ink-mid);
      border-radius: 3px;
      background: var(--color-panel);
      font-family: var(--font-mono);
