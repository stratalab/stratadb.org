                  <text x="116" y="33" text-anchor="middle" style="font-family:var(--font-mono);font-size:8.5px;fill:var(--color-strata-json)">JSON</text>
                  <rect x="158" y="20" width="52" height="20" rx="3" style="fill:color-mix(in srgb, var(--color-strata-event) 14%, var(--color-panel));stroke:var(--color-strata-event);stroke-width:1.25" />
                  <text x="184" y="33" text-anchor="middle" style="font-family:var(--font-mono);font-size:8.5px;fill:var(--color-strata-event)">Event</text>
