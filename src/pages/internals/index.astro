      color: var(--ember);
    }
    .icp-name {
      margin-top: 0.85rem;
      font-size: 1.18rem;
      font-weight: 600;
      letter-spacing: -0.014em;
      color: var(--color-ink-hi);
    }
    .icp-desc {
      margin-top: 0.6rem;
      font-size: 0.9rem;
      line-height: 1.6;
      color: var(--color-ink-mid);
    }

    /* ===== §5 · product architecture — the five crates ============== */
    .crates {
      margin-top: 1.2rem;
    }
    .crates-tag {
      font-family: var(--font-mono);
      font-size: 0.66rem;
      letter-spacing: 0.13em;
      text-transform: uppercase;
      color: var(--color-ink-low);
      margin-bottom: 0.7rem;
    }
    .crate-spine {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      max-width: 46rem;
    }
    .crate {
      padding: 0.7rem 1.2rem 0.78rem;
      border: 1px solid var(--color-line);
      border-radius: var(--radius-card);
      background: var(--color-panel);
      box-shadow: var(--shadow-panel);
    }
    .crate-h {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 0.8rem;
    }
    .crate-name {
      font-size: 1.12rem;
      font-weight: 600;
      letter-spacing: -0.014em;
      color: var(--color-ink-hi);
    }
    .crate-role {
      font-family: var(--font-mono);
      font-size: 0.64rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--color-ink-low);
      white-space: nowrap;
    }
    .crate-desc {
      margin-top: 0.4rem;
      font-size: 0.9rem;
      line-height: 1.5;
      color: var(--color-ink-mid);
    }
    .crate-prims {
      display: flex;
      flex-wrap: wrap;
      gap: 0.4rem;
      margin-top: 0.75rem;
    }
    .prim {
      font-family: var(--font-mono);
      font-size: 0.66rem;
      font-weight: 600;
      padding: 0.14rem 0.5rem;
      border-radius: 4px;
      border: 1px solid color-mix(in srgb, var(--hue) 42%, transparent);
      background: color-mix(in srgb, var(--hue) 12%, var(--color-panel));
      color: var(--hue);
    }
    .crate-bridge {
      border-left: 2px solid var(--ember);
    }
    .crate-drill {
      margin-top: 0.65rem;
      font-family: var(--font-mono);
      font-size: 0.68rem;
      letter-spacing: 0.02em;
      color: var(--ember);
    }
    .crate-base {
      background: color-mix(in srgb, var(--color-ink-hi) 3%, var(--color-panel));
    }

    /* ===== §6 · architecture — section intro ========================= */
    .arch-intro {
      max-width: 52rem;
    }

    /* ===== §6 · architecture — screen 2 (storage explorer) =========== */
    .explorer {
      display: grid;
      grid-template-columns: 16.5rem minmax(0, 1fr);
      margin-top: 2.25rem;
      border: 1px solid var(--color-line);
      border-radius: var(--radius-card);
      background: var(--color-panel);
      box-shadow: var(--shadow-panel);
      overflow: hidden;
    }
    @media (max-width: 880px) {
      .explorer {
        grid-template-columns: 1fr;
      }
    }
    .explorer-index {
      display: flex;
      flex-direction: column;
      padding: 1rem 0.8rem 0.9rem;
      border-right: 1px solid var(--color-line);
      background: color-mix(in srgb, var(--color-ink-hi) 2%, var(--color-panel));
    }
    @media (max-width: 880px) {
      .explorer-index {
        border-right: none;
        border-bottom: 1px solid var(--color-line);
      }
    }
    .explorer-tag {
      margin: 0 0 0.7rem 0.3rem;
      font-family: var(--font-mono);
      font-size: 0.62rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--color-ink-low);
    }
    .explorer-list {
      list-style: none;
      margin: 0;
      padding: 0;
      display: flex;
      flex-direction: column;
      gap: 0.15rem;
    }
    .explorer-node {
      position: relative;
      display: grid;
      grid-template-columns: 1.9rem 1fr;
      align-items: center;
      column-gap: 0.55rem;
      width: 100%;
      padding: 0.55rem 0.6rem;
      border: 0;
      border-radius: var(--radius-control);
      background: transparent;
      text-align: left;
      cursor: pointer;
      transition: background var(--dur-2) var(--ease-out);
    }
    .explorer-node:hover {
      background: color-mix(in srgb, var(--color-ink-hi) 3.5%, transparent);
    }
    .explorer-node-k {
      grid-row: 1 / span 2;
      font-family: var(--font-mono);
      font-size: 0.66rem;
      color: var(--color-ink-low);
      text-align: center;
    }
    .explorer-node-name {
      font-size: 0.9rem;
      font-weight: 500;
      line-height: 1.2;
      color: var(--color-ink-mid);
    }
    .explorer-node-sub {
      font-family: var(--font-mono);
      font-size: 0.62rem;
      color: var(--color-ink-low);
    }
    .explorer-node.is-active {
      background: var(--ember-soft);
      box-shadow: inset 2px 0 0 var(--ember);
    }
    .explorer-node.is-active .explorer-node-k {
      color: var(--ember);
    }
    .explorer-node.is-active .explorer-node-name {
      color: var(--color-terracotta-700);
      font-weight: 600;
    }
    .explorer-detail {
      position: relative;
      padding: 1.5rem 1.7rem 1.6rem;
    }
    @media (max-width: 880px) {
      .explorer-detail {
        padding: 1.3rem 1.2rem;
      }
    }
    .explorer-pane {
      display: none;
    }
    .explorer-pane.is-active {
      display: block;
    }
    @media (prefers-reduced-motion: no-preference) {
      .explorer-pane.is-active {
        animation: pane-in 0.32s var(--ease-out) both;
      }
    }
    @keyframes pane-in {
      from {
        opacity: 0;
        transform: translateY(6px);
      }
      to {
        opacity: 1;
        transform: none;
      }
    }
    .pane-head {
      display: flex;
      align-items: baseline;
      gap: 0.7rem;
    }
    .pane-layer {
      padding: 0.1rem 0.45rem;
      font-family: var(--font-mono);
      font-size: 0.66rem;
      font-weight: 500;
      letter-spacing: 0.04em;
      color: var(--ember);
      border: 1px solid color-mix(in srgb, var(--ember) 38%, transparent);
      border-radius: 999px;
    }
    .pane-name {
      font-size: 1.3rem;
      font-weight: 600;
      letter-spacing: -0.015em;
      color: var(--color-ink-hi);
    }
    .pane-desc {
      margin-top: 0.7rem;
      max-width: 44rem;
      font-size: 0.94rem;
      line-height: 1.6;
      color: var(--color-ink-mid);
    }
    .pane-svg {
      margin: 1.15rem 0 0;
      padding: 0.6rem 0.9rem;
      border: 1px solid var(--color-line);
      border-radius: var(--radius-card);
      background: color-mix(in srgb, var(--color-ink-hi) 1.5%, var(--color-panel));
    }
    .pane-svg svg {
      display: block;
      width: 100%;
      height: auto;
      max-height: 11rem;
    }
    .pane-show {
      margin-top: 1rem;
      font-family: var(--font-mono);
      font-size: 0.74rem;
      line-height: 1.5;
      color: var(--color-ink-low);
      text-wrap: pretty;
    }
    .pane-show-k {
      color: var(--ember);
      margin-right: 0.5rem;
    }

    /* ===== §6 · L5 living-LSM interactive ============================ */
    .lsm {
      margin-top: 1.1rem;
    }
    .lsm-stage {
      position: relative;
      display: flex;
      flex-direction: column;
      gap: 0.28rem;
      padding: 0.85rem 1rem 0.95rem;
      border: 1px solid var(--color-line);
      border-radius: var(--radius-card);
      background: color-mix(in srgb, var(--color-ink-hi) 1.5%, var(--color-panel));
    }
    .lsm-level {
      display: grid;
      grid-template-columns: 2.1rem 1fr 5.4rem;
      align-items: center;
      gap: 0.6rem;
      padding: 0.34rem 0.4rem;
      border-radius: var(--radius-control);
      transition: box-shadow var(--dur-2) var(--ease-out), background var(--dur-2) var(--ease-out);
    }
    .lsm-level.is-active {
      background: color-mix(in srgb, var(--ember) 7%, transparent);
      box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--ember) 38%, transparent);
    }
    .lsm-level.is-probing {
      box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--ember) 55%, transparent);
    }
    .lsm-tag {
      font-family: var(--font-mono);
      font-size: 0.64rem;
      letter-spacing: 0.04em;
      color: var(--color-ink-low);
    }
    .lsm-meta {
      font-family: var(--font-mono);
      font-size: 0.6rem;
      color: var(--color-ink-low);
      text-align: right;
    }
    .lsm-slots {
      display: flex;
      gap: 0.3rem;
    }
    .lsm-slot,
    .lsm-chip {
      width: 2.7rem;
      height: 1.15rem;
      border-radius: 3px;
    }
    .lsm-slot {
      border: 1px dashed var(--color-line-hover);
    }
    .lsm-chip {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border: 1px solid color-mix(in srgb, var(--ember) 45%, transparent);
      background: var(--ember-soft);
      font-family: var(--font-mono);
      font-size: 0.66rem;
      color: var(--color-terracotta-700);
    }
    .lsm-tiles {
      display: flex;
      gap: 0.35rem;
    }
    .lsm-tile {
      min-width: 3.2rem;
      height: 1.25rem;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 0 0.45rem;
      border: 1px solid var(--color-ink-mid);
      border-radius: 3px;
      background: var(--color-panel);
      font-family: var(--font-mono);
      font-size: 0.62rem;
      color: var(--color-ink-mid);
    }
    .lsm-runs {
      display: flex;
      gap: 0.3rem;
      width: 100%;
    }
    .lsm-run {
      flex: 1;
      height: 1.2rem;
      display: flex;
      align-items: center;
      justify-content: center;
      border: 1px solid var(--color-ink-mid);
      border-radius: 3px;
      background: var(--color-panel);
      font-family: var(--font-mono);
      font-size: 0.62rem;
      color: var(--color-ink-mid);
    }
    .lsm-level.is-hit .lsm-run {
      border-color: var(--ember);
      background: var(--ember-soft);
      color: var(--color-terracotta-700);
    }
    .lsm-base {
      height: 0.95rem;
      border-radius: 3px;
      background: color-mix(in srgb, var(--color-ink-hi) 8%, var(--color-panel));
      border: 1px solid var(--color-line-hover);
    }
    .lsm-flow {
      display: flex;
      align-items: center;
      gap: 0.7rem;
      padding-left: 2.7rem;
      min-height: 0.95rem;
      font-family: var(--font-mono);
      font-size: 0.6rem;
      color: var(--color-ink-low);
      transition: color var(--dur-2) var(--ease-out);
    }
    .lsm-flow em {
      font-style: normal;
      color: var(--color-ink-low);
      opacity: 0.7;
    }
    .lsm-flow.is-active,
    .lsm-flow.is-active em {
      color: var(--ember);
      opacity: 1;
    }
    .lsm-read {
      position: absolute;
      top: 0.5rem;
      right: 0.6rem;
      padding: 0.1rem 0.5rem;
      border: 1px solid color-mix(in srgb, var(--ember) 40%, transparent);
      border-radius: 999px;
      background: var(--ember-soft);
      font-family: var(--font-mono);
      font-size: 0.62rem;
      color: var(--color-terracotta-700);
    }
    .lsm-read[hidden] {
      display: none;
    }
    .lsm-stage.is-reading [data-lsm-memmeta] {
      visibility: hidden;
    }
    .lsm-note {
      margin-top: 0.7rem;
      min-height: 2.55rem;
      font-family: var(--font-mono);
      font-size: 0.72rem;
      line-height: 1.5;
      color: var(--color-ink-mid);
      text-wrap: pretty;
    }
    .lsm-controls {
      display: flex;
      align-items: center;
      gap: 0.4rem;
    }
    .lsm-btn {
      padding: 0.32rem 0.62rem;
      border: 1px solid var(--color-line-hover);
      border-radius: var(--radius-control);
      background: var(--color-panel);
      font-family: var(--font-mono);
      font-size: 0.7rem;
      color: var(--color-ink-mid);
      cursor: pointer;
      transition: border-color var(--dur-2) var(--ease-out), color var(--dur-2) var(--ease-out);
    }
    .lsm-btn:hover {
      border-color: var(--color-ink-mid);
      color: var(--color-ink-hi);
    }
    .lsm-btn-primary {
      border-color: color-mix(in srgb, var(--ember) 45%, transparent);
      background: var(--ember-soft);
      color: var(--color-terracotta-700);
    }
    .lsm-btn-primary:hover {
      border-color: var(--ember);
      color: var(--color-terracotta-700);
    }
    .lsm-btn:disabled {
      opacity: 0.4;
      cursor: default;
    }
    .lsm-count {
      margin-left: auto;
      font-family: var(--font-mono);
      font-size: 0.66rem;
      color: var(--color-ink-low);
    }
    @keyframes lsm-in {
      from {
        opacity: 0;
        transform: translateY(-3px);
      }
      to {
        opacity: 1;
        transform: none;
      }
    }
    @keyframes lsm-pulse {
      0%, 100% {
        box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--ember) 55%, transparent);
      }
      50% {
        box-shadow: inset 0 0 0 2px var(--ember);
      }
    }
    @media (prefers-reduced-motion: no-preference) {
      .lsm-in {
        animation: lsm-in 0.26s var(--ease-out) both;
      }
      .lsm-level.is-probing {
        animation: lsm-pulse 0.62s var(--ease-out);
      }
    }

    /* ===== §6 · L6 branch-fork interactive =========================== */
    .bf {
      margin-top: 1.1rem;
    }
    .bf-stage {
      display: flex;
      flex-direction: column;
      gap: 0.36rem;
      padding: 0.6rem 1rem 0.68rem;
      border: 1px solid var(--color-line);
      border-radius: var(--radius-card);
      background: color-mix(in srgb, var(--color-ink-hi) 1.5%, var(--color-panel));
    }
    .bf-key {
      font-family: var(--font-mono);
      font-size: 0.62rem;
      letter-spacing: 0.04em;
      color: var(--color-ink-low);
    }
    .bf-key b {
      color: var(--color-ink-hi);
      font-weight: 600;
    }
    .bf-heads,
    .bf-reads {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.8rem;
    }
    .bf-head {
      display: flex;
      flex-direction: column;
      gap: 0.3rem;
    }
    .bf-head-label {
      font-family: var(--font-mono);
      font-size: 0.7rem;
      font-weight: 600;
      color: var(--color-ink-hi);
    }
    .bf-cells {
      display: flex;
      flex-direction: column;
      gap: 0.26rem;
    }
    .bf-cell {
      display: grid;
      grid-template-columns: 2.1rem 1fr;
      align-items: center;
      gap: 0.5rem;
      height: 1.25rem;
      padding: 0 0.55rem;
      border: 1px solid var(--color-ink-mid);
      border-radius: 3px;
      background: var(--color-panel);
      font-family: var(--font-mono);
    }
    .bf-cell .bf-v {
      font-size: 0.58rem;
      color: var(--color-ink-low);
    }
    .bf-cell .bf-val {
      font-size: 0.66rem;
      color: var(--color-ink-hi);
    }
    .bf-cell.is-inherited {
      border-style: dashed;
      border-color: var(--color-line-hover);
      background: transparent;
    }
    .bf-cell.is-inherited .bf-val {
      color: var(--color-ink-mid);
    }
    .bf-cell.is-hot {
      border-style: solid;
      border-color: var(--ember);
      background: var(--ember-soft);
    }
    .bf-cell.is-hot .bf-v {
      color: var(--ember);
    }
    .bf-cell.is-hot .bf-val {
      color: var(--color-terracotta-700);
      font-weight: 600;
    }
    .bf-ghost {
      display: flex;
      align-items: center;
      height: 1.25rem;
      padding: 0 0.55rem;
      border: 1px dashed var(--color-line-hover);
      border-radius: 3px;
      font-family: var(--font-mono);
      font-size: 0.62rem;
      color: var(--color-ink-low);
    }
    .bf-gate {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.05rem 0;
      font-family: var(--font-mono);
      font-size: 0.62rem;
      color: var(--ember);
    }
    .bf-gate::before,
    .bf-gate::after {
      content: '';
      flex: 1;
      border-top: 1px dashed var(--ember);
    }
    .bf-gate[hidden] {
      display: none;
    }
    .bf-base {
      display: flex;
      flex-direction: column;
      gap: 0.3rem;
    }
    .bf-base-label {
      font-family: var(--font-mono);
      font-size: 0.6rem;
      letter-spacing: 0.04em;
      color: var(--color-ink-low);
    }
    .bf-read {
      font-family: var(--font-mono);
      font-size: 0.66rem;
      color: var(--color-ink-mid);
    }
    .bf-read b {
      color: var(--color-terracotta-700);
      font-weight: 600;
    }
    .bf-read[hidden] {
      display: none;
    }
    @media (prefers-reduced-motion: no-preference) {
      .bf-cell.lsm-in {
        animation: lsm-in 0.26s var(--ease-out) both;
      }
    }

    /* ===== §7 · vector architecture — per-slab index on the LSM ====== */
    .varch-top {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.4rem;
      align-items: start;
      margin-top: 1rem;
    }
    @media (max-width: 860px) {
      .varch-top {
        grid-template-columns: 1fr;
      }
    }
    .vstack {
      display: flex;
      flex-direction: column;
      gap: 0.26rem;
      padding: 0.7rem 0.9rem 0.78rem;
      border: 1px solid var(--color-line);
      border-radius: var(--radius-card);
      background: color-mix(in srgb, var(--color-ink-hi) 1.5%, var(--color-panel));
    }
    .vstack-tag {
      font-family: var(--font-mono);
      font-size: 0.6rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--color-ink-low);
      margin-bottom: 0.3rem;
    }
    .vlevel {
      display: grid;
      grid-template-columns: 4.4rem 1fr auto;
      align-items: baseline;
      gap: 0.6rem;
      padding: 0.32rem 0.6rem;
      border-radius: var(--radius-control);
      background: color-mix(in srgb, var(--color-ink-hi) 3%, var(--color-panel));
    }
    .vlevel-base {
      background: color-mix(in srgb, var(--color-ink-hi) 6.5%, var(--color-panel));
    }
    .vlevel-k {
      font-family: var(--font-mono);
      font-size: 0.74rem;
      font-weight: 600;
      color: var(--color-ink-hi);
    }
    .vlevel-holds {
      font-size: 0.82rem;
      color: var(--color-ink-mid);
    }
    .vlevel-idx {
      font-family: var(--font-mono);
      font-size: 0.66rem;
      color: var(--color-ink-mid);
      text-align: right;
    }
    .vlevel-idx em {
      font-style: normal;
      color: var(--ember);
    }
    .vflow {
      padding-left: 0.6rem;
      font-family: var(--font-mono);
      font-size: 0.6rem;
      letter-spacing: 0.01em;
      color: var(--color-ink-low);
    }
    .vflow-key {
      color: var(--ember);
    }
    .vstack-note {
      margin-top: 0.4rem;
      font-family: var(--font-mono);
      font-size: 0.58rem;
      line-height: 1.55;
      color: var(--color-ink-low);
    }
    .vq-cap {
      margin-top: 0.7rem;
      font-size: 0.82rem;
      line-height: 1.5;
      color: var(--color-ink-mid);
    }
    .varch-cards {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1rem;
      margin-top: 0.85rem;
    }
    @media (max-width: 860px) {
      .varch-cards {
        grid-template-columns: 1fr;
      }
    }
    .vcard-tag {
      font-family: var(--font-mono);
      font-size: 0.6rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--color-ink-low);
    }
    .vcard-name {
      margin-top: 0.35rem;
      font-size: 1rem;
      font-weight: 600;
      letter-spacing: -0.012em;
      line-height: 1.2;
      color: var(--color-ink-hi);
    }

    /* ===== §9 · benchmarks =========================================== */
    .bench-illustrative {
      margin-top: 1.4rem;
      max-width: 46rem;
      padding: 0.6rem 0.9rem;
      border: 1px dashed color-mix(in srgb, var(--ember) 45%, transparent);
      border-radius: var(--radius-control);
      background: var(--ember-soft);
      font-family: var(--font-mono);
      font-size: 0.72rem;
      line-height: 1.5;
      color: var(--color-ink-mid);
    }
    .bench-illustrative span {
      margin-right: 0.55rem;
      font-size: 0.62rem;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--color-terracotta-700);
    }
    .bench-grid {
      margin-top: 1.5rem;
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }
    .bench-panel {
      padding: 1rem 1.25rem 1.05rem;
      border: 1px solid var(--color-line);
      border-radius: var(--radius-card);
      background: var(--color-panel);
      box-shadow: var(--shadow-panel);
    }
    .bench-head {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 1rem;
      padding-bottom: 0.6rem;
      border-bottom: 1px solid var(--color-line);
    }
    .bench-name {
      font-size: 1.08rem;
      font-weight: 600;
      letter-spacing: -0.014em;
      color: var(--color-ink-hi);
    }
    .bench-sub {
      font-family: var(--font-mono);
      font-size: 0.7rem;
      letter-spacing: 0.04em;
      color: var(--color-ink-low);
    }
    /* KV — grouped bars per YCSB workload (Strata in ember) */
    .bench-bars {
      margin-top: 0.1rem;
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      column-gap: 1.9rem;
    }
    @media (max-width: 880px) {
      .bench-bars {
        grid-template-columns: 1fr 1fr;
      }
    }
    @media (max-width: 560px) {
      .bench-bars {
        grid-template-columns: 1fr;
      }
    }
    .bench-group {
      padding-top: 0.55rem;
    }
    .bench-wl {
      margin-bottom: 0.42rem;
      font-family: var(--font-mono);
      font-size: 0.74rem;
      color: var(--color-ink-mid);
    }
    .bench-wl b {
      margin-right: 0.5rem;
      color: var(--color-ink-hi);
    }
    .bench-bar {
      display: grid;
      grid-template-columns: 3.9rem 1fr 3.3rem;
      align-items: center;
      gap: 0.65rem;
      padding: 0.08rem 0;
    }
    .bench-bar-label {
      font-family: var(--font-mono);
      font-size: 0.7rem;
      color: var(--color-ink-low);
    }
    .bench-bar-track {
      height: 0.52rem;
      border-radius: 3px;
      background: color-mix(in srgb, var(--color-ink-hi) 6%, var(--color-panel));
      overflow: hidden;
    }
    .bench-bar-fill {
      display: block;
      height: 100%;
      border-radius: 3px;
      background: color-mix(in srgb, var(--color-ink-hi) 24%, transparent);
    }
    .bench-bar-val {
      font-family: var(--font-mono);
      font-size: 0.7rem;
      text-align: right;
      color: var(--color-ink-mid);
      font-variant-numeric: tabular-nums;
    }
    .bench-bar.is-strata .bench-bar-fill {
      background: var(--ember);
    }
    .bench-bar.is-strata .bench-bar-label {
      color: var(--color-ink-hi);
      font-weight: 500;
    }
    .bench-bar.is-strata .bench-bar-val {
      color: var(--color-terracotta-700);
    }

    /* Vector — solo; five metrics, each its own card, charted across sizes */
    .vmetrics {
      margin-top: 0.7rem;
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 0.8rem;
    }
    @media (max-width: 820px) {
      .vmetrics {
        grid-template-columns: repeat(2, 1fr);
      }
    }
    .vmetric {
      padding: 0.7rem 0.8rem 0.6rem;
      border: 1px solid var(--color-line);
      border-radius: var(--radius-control);
      background: color-mix(in srgb, var(--color-ink-hi) 2%, var(--color-panel));
    }
    .vmetric-top {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 0.35rem;
      margin-bottom: 0.7rem;
    }
    .vmetric-name {
      font-family: var(--font-mono);
      font-size: 0.66rem;
      letter-spacing: 0.01em;
      color: var(--color-ink-hi);
    }
    .vmetric-unit {
      color: var(--color-ink-low);
    }
    .vmetric-dir {
      flex-shrink: 0;
      font-family: var(--font-mono);
      font-size: 0.72rem;
      line-height: 1;
      color: var(--color-ink-low);
    }
    .vmetric-bars {
      display: flex;
      align-items: flex-end;
      gap: 0.4rem;
      height: 3rem;
    }
    .vm-col {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: flex-end;
      height: 100%;
    }
    .vm-v {
      margin-bottom: 0.26rem;
      font-family: var(--font-mono);
      font-size: 0.62rem;
      color: var(--color-ink-hi);
      white-space: nowrap;
      font-variant-numeric: tabular-nums;
    }
    .vm-bar {
      width: 70%;
      max-width: 1.3rem;
      border-radius: 2px 2px 0 0;
      background: var(--ember);
    }
    .vmetric-xs {
      display: flex;
      gap: 0.4rem;
      margin-top: 0.4rem;
      padding-top: 0.32rem;
      border-top: 1px solid var(--color-line);
    }
    .vmetric-xs span {
      flex: 1;
      text-align: center;
      font-family: var(--font-mono);
      font-size: 0.58rem;
      color: var(--color-ink-low);
    }
    .bench-foot {
      margin-top: 0.7rem;
      font-family: var(--font-mono);
      font-size: 0.64rem;
      line-height: 1.5;
      color: var(--color-ink-low);
    }

  </style>

  <script>
    // §4 storage explorer — select a layer, swap its detail pane.
    const explorer = document.querySelector('.explorer');
    if (explorer) {
      const nodes = explorer.querySelectorAll<HTMLElement>('[data-node]');
      const panes = explorer.querySelectorAll<HTMLElement>('[data-pane]');
      const select = (key: string | undefined) => {
        if (!key) return;
        nodes.forEach((n) => n.classList.toggle('is-active', n.dataset.node === key));
        panes.forEach((p) => p.classList.toggle('is-active', p.dataset.pane === key));
      };
      nodes.forEach((n) => n.addEventListener('click', () => select(n.dataset.node)));
    }

    // §4 · L5 living-LSM — deterministic, precomputed frames: write → flush → compaction → read.
    interface LsmFrame {
      mem: string[];
      l0: string[];
      l1: string[];
      note: string;
      active?: 'mem' | 'l0' | 'l1';
      flow?: 'flush' | 'compact';
      read?: string;
      probe?: 'mem' | 'l0' | 'l1';
      hit?: 'mem' | 'l0' | 'l1';
    }
    const lsm = document.querySelector<HTMLElement>('[data-lsm]');
    if (lsm) {
      const F: LsmFrame[] = [
        { mem: [], l0: [], l1: [], note: 'An LSM batches writes in memory, then flushes sorted tables to disk. Step ▸ to follow one through.' },
        { mem: ['a'], l0: [], l1: [], active: 'mem', note: 'write a → memtable — held in memory, kept sorted.' },
        { mem: ['a', 'b'], l0: [], l1: [], active: 'mem', note: 'write b → memtable. No disk seek yet; writes stay sequential.' },
        { mem: ['a', 'b', 'c'], l0: [], l1: [], active: 'mem', note: 'write c → the memtable is full (3 / 3).' },
        { mem: [], l0: ['a–c'], l1: [], active: 'l0', flow: 'flush', note: 'flush → one immutable L0 table, written in one sequential pass. The memtable clears.' },
        { mem: ['d', 'e', 'f'], l0: ['a–c'], l1: [], active: 'mem', note: 'more writes fill the next memtable.' },
        { mem: [], l0: ['a–c', 'd–f'], l1: [], active: 'l0', flow: 'flush', note: 'flush → a second L0 table.' },
        { mem: [], l0: ['a–c', 'd–f', 'a–e'], l1: [], active: 'l0', flow: 'flush', note: 'a third flush — L0 tables may overlap in key range (a–c, d–f, a–e), so a read may touch several.' },
        { mem: [], l0: [], l1: ['a–f'], active: 'l1', flow: 'compact', note: 'L0 reaches its threshold, so compaction merges all three into one sorted, non-overlapping L1 run. The caller supplies the prune / tombstone / TTL policy that the compaction applies.' },
        { mem: ['g', 'h', 'i'], l0: [], l1: ['a–f'], active: 'mem', note: 'writes keep landing in memory, on top of the merged level.' },
        { mem: [], l0: ['g–i'], l1: ['a–f'], active: 'l0', flow: 'flush', note: 'flush → a fresh L0 table now sits above the L1 run.' },
        { mem: ['k'], l0: ['g–i'], l1: ['a–f'], active: 'mem', note: 'one more write waits in the memtable.' },
        { mem: ['k'], l0: ['g–i'], l1: ['a–f'], read: 'b', probe: 'mem', note: 'read b → check the memtable first… not here.' },
        { mem: ['k'], l0: ['g–i'], l1: ['a–f'], read: 'b', probe: 'l0', note: '…then L0, newest table first… b is not in g–i.' },
        { mem: ['k'], l0: ['g–i'], l1: ['a–f'], read: 'b', probe: 'l1', hit: 'l1', note: '…then L1 → found. The search stops at the first match and returns the newest version of b.' },
      ];

      const elStage = lsm.querySelector<HTMLElement>('.lsm-stage')!;
      // Scoped-CSS bridge: stamp Astro's component scope attribute onto JS-built
      // elements so the scoped .lsm-chip / .lsm-tile / .lsm-run rules match them.
      const scopeAttr = Array.from(elStage.attributes).map((a) => a.name).find((n) => n.startsWith('data-astro-cid-')) ?? '';
      const elMem = lsm.querySelector<HTMLElement>('[data-lsm-mem]')!;
      const elMemMeta = lsm.querySelector<HTMLElement>('[data-lsm-memmeta]')!;
      const elL0 = lsm.querySelector<HTMLElement>('[data-lsm-l0]')!;
      const elL1 = lsm.querySelector<HTMLElement>('[data-lsm-l1]')!;
      const elNote = lsm.querySelector<HTMLElement>('[data-lsm-note]')!;
      const elCount = lsm.querySelector<HTMLElement>('[data-lsm-count]')!;
      const elRead = lsm.querySelector<HTMLElement>('[data-lsm-read]')!;
      const btnNext = lsm.querySelector<HTMLButtonElement>('[data-lsm-next]')!;
      const btnPrev = lsm.querySelector<HTMLButtonElement>('[data-lsm-prev]')!;
      const btnReset = lsm.querySelector<HTMLButtonElement>('[data-lsm-reset]')!;
      const btnPlay = lsm.querySelector<HTMLButtonElement>('[data-lsm-play]')!;
      const levels: Record<string, HTMLElement> = {};
      lsm.querySelectorAll<HTMLElement>('[data-lsm-level]').forEach((l) => { levels[l.dataset.lsmLevel!] = l; });
      const flows: Record<string, HTMLElement> = {};
      lsm.querySelectorAll<HTMLElement>('[data-lsm-flow]').forEach((f) => { flows[f.dataset.lsmFlow!] = f; });

      let i = 0;
      let timer: ReturnType<typeof setInterval> | null = null;

      const render = () => {
        const f = F[i];
        let mem = '';
        for (let s = 0; s < 3; s++) {
          mem += f.mem[s]
            ? `<span class="lsm-chip${f.active === 'mem' && s === f.mem.length - 1 ? ' lsm-in' : ''}" ${scopeAttr}>${f.mem[s]}</span>`
            : `<span class="lsm-slot" ${scopeAttr}></span>`;
        }
        elMem.innerHTML = mem;
        elMemMeta.textContent = `${f.mem.length} / 3`;
        elL0.innerHTML = f.l0
          .map((r, idx) => `<span class="lsm-tile${f.active === 'l0' && idx === f.l0.length - 1 ? ' lsm-in' : ''}" ${scopeAttr}>${r}</span>`)
          .join('');
        elL1.innerHTML = f.l1
          .map((r) => `<span class="lsm-run${f.active === 'l1' ? ' lsm-in' : ''}" ${scopeAttr}>${r} · sorted</span>`)
          .join('');
        elNote.textContent = f.note;
        elCount.textContent = `${String(i).padStart(2, '0')} / ${String(F.length - 1).padStart(2, '0')}`;
        for (const key of Object.keys(levels)) {
          levels[key].classList.toggle('is-active', f.active === key && !f.read);
          levels[key].classList.toggle('is-probing', f.probe === key);
          levels[key].classList.toggle('is-hit', f.hit === key);
        }
        for (const key of Object.keys(flows)) {
          flows[key].classList.toggle('is-active', f.flow === key);
        }
        if (f.read) {
          elRead.textContent = `read ${f.read}`;
          elRead.hidden = false;
        } else {
          elRead.hidden = true;
        }
        elStage.classList.toggle('is-reading', !!f.read);
        btnPrev.disabled = i === 0;
        btnNext.disabled = i === F.length - 1;
      };

      const go = (n: number) => { i = Math.max(0, Math.min(F.length - 1, n)); render(); };
      const stopPlay = () => {
        if (timer) { clearInterval(timer); timer = null; }
        btnPlay.textContent = 'play';
      };
      btnNext.addEventListener('click', () => { stopPlay(); go(i + 1); });
      btnPrev.addEventListener('click', () => { stopPlay(); go(i - 1); });
      btnReset.addEventListener('click', () => { stopPlay(); go(0); });
      btnPlay.addEventListener('click', () => {
        if (timer) { stopPlay(); return; }
        if (i === F.length - 1) go(0);
        btnPlay.textContent = 'pause';
        timer = setInterval(() => {
          if (i >= F.length - 1) { stopPlay(); return; }
          go(i + 1);
        }, 1150);
      });

      render();
    }

    // §4 · L6 branch-fork — fork (O(metadata)) → write each branch → one key's reads diverge.
    interface BfCell {
      v: string;
      val: string;
    }
    interface BfFrame {
      fork: boolean;
      baseLabel: string;
      mainHead: BfCell[];
      forkHead: BfCell[];
      base: BfCell[];
      hot: Record<string, string>;
      readMain: string;
      readFork: string | null;
      readForkAs?: string;
      note: string;
    }
    const bf = document.querySelector<HTMLElement>('[data-bf]');
    if (bf) {
      const BASE: BfCell[] = [{ v: 'v5', val: 'c' }, { v: 'v3', val: 'b' }, { v: 'v1', val: 'a' }];
      const BF: BfFrame[] = [
        { fork: false, baseLabel: 'main · versions of k', mainHead: [], forkHead: [], base: BASE,
          hot: { v5: 'main' }, readMain: 'c', readFork: null,
          note: 'main holds one key k with three versions — v1, v3, v5 — newest first. A read returns the newest: c.' },
        { fork: true, baseLabel: 'shared base · inherited by reference', mainHead: [], forkHead: [], base: BASE,
          hot: { v5: 'both' }, readMain: 'c', readFork: 'c',
          note: 'Fork main. O(metadata) — zero rows copied; the fork inherits main’s layers by reference, gated at v5. Both branches read c.' },
        { fork: true, baseLabel: 'shared base · inherited by reference', mainHead: [], forkHead: [{ v: 'v6', val: 'x' }], base: BASE,
          hot: { v6: 'fork', v5: 'main' }, readMain: 'c', readFork: 'x',
          note: 'Write k=x on the fork. It lands in the fork’s own layer (v6) and shadows the inherited base. The fork now reads x; main still reads c.' },
        { fork: true, baseLabel: 'shared base · inherited by reference', mainHead: [{ v: 'v7', val: 'y' }], forkHead: [{ v: 'v6', val: 'x' }], base: BASE,
          hot: { v7: 'main', v6: 'fork' }, readMain: 'y', readFork: 'x',
          note: 'Write k=y on main (v7). The fork’s gate stays pinned at v5, so it never sees v7. The same key now reads y on main and x on the fork, from one shared base.' },
        { fork: true, baseLabel: 'shared base · inherited by reference', mainHead: [{ v: 'v7', val: 'y' }], forkHead: [{ v: 'v6', val: 'x' }], base: BASE,
          hot: { v7: 'main', v3: 'fork' }, readMain: 'y', readFork: 'b', readForkAs: '@ v3',
          note: 'An as-of read works on the fork too: reading k as-of v3 returns b, found by walking the inherited chain. The same newest-first ordering serves latest, as-of, and history reads.' },
      ];

      const bfStage = bf.querySelector<HTMLElement>('.bf-stage')!;
      const bfScope = Array.from(bfStage.attributes).map((a) => a.name).find((n) => n.startsWith('data-astro-cid-')) ?? '';
      const elMainHead = bf.querySelector<HTMLElement>('[data-bf-mainhead]')!;
      const elForkHead = bf.querySelector<HTMLElement>('[data-bf-forkhead]')!;
      const elGate = bf.querySelector<HTMLElement>('[data-bf-gate]')!;
      const elBaseLabel = bf.querySelector<HTMLElement>('[data-bf-baselabel]')!;
      const elBase = bf.querySelector<HTMLElement>('[data-bf-base]')!;
      const elReadMain = bf.querySelector<HTMLElement>('[data-bf-readmain]')!;
      const elReadFork = bf.querySelector<HTMLElement>('[data-bf-readfork]')!;
      const elNote = bf.querySelector<HTMLElement>('[data-bf-note]')!;
      const elCount = bf.querySelector<HTMLElement>('[data-bf-count]')!;
      const btnNext = bf.querySelector<HTMLButtonElement>('[data-bf-next]')!;
      const btnPrev = bf.querySelector<HTMLButtonElement>('[data-bf-prev]')!;
      const btnReset = bf.querySelector<HTMLButtonElement>('[data-bf-reset]')!;
      const btnPlay = bf.querySelector<HTMLButtonElement>('[data-bf-play]')!;

      let bi = 0;
      let bfTimer: ReturnType<typeof setInterval> | null = null;

      const cellInner = (c: BfCell) => `<span class="bf-v" ${bfScope}>${c.v}</span><span class="bf-val" ${bfScope}>${c.val}</span>`;
      const ownCell = (c: BfCell, hot: boolean) =>
        `<div class="bf-cell${hot ? ' is-hot' : ''} lsm-in" ${bfScope}>${cellInner(c)}</div>`;
      const baseCell = (c: BfCell, hot: boolean, inherited: boolean) =>
        `<div class="bf-cell${inherited ? ' is-inherited' : ''}${hot ? ' is-hot' : ''}" ${bfScope}>${cellInner(c)}</div>`;
      const ghost = (t: string) => `<div class="bf-ghost" ${bfScope}>${t}</div>`;

      const renderBf = () => {
        const f = BF[bi];
        elMainHead.innerHTML = f.mainHead.length
          ? f.mainHead.map((c) => ownCell(c, !!f.hot[c.v])).join('')
          : ghost('latest in base ↓');
        elForkHead.innerHTML = !f.fork
          ? ghost('— not forked —')
          : f.forkHead.length
            ? f.forkHead.map((c) => ownCell(c, !!f.hot[c.v])).join('')
            : ghost('inherits base ↓');
        elGate.hidden = !f.fork;
        elBaseLabel.textContent = f.baseLabel;
        elBase.innerHTML = f.base.map((c) => baseCell(c, !!f.hot[c.v], f.fork)).join('');
        elReadMain.innerHTML = `main reads k = <b ${bfScope}>${f.readMain}</b>`;
        if (f.readFork == null) {
          elReadFork.hidden = true;
        } else {
          elReadFork.hidden = false;
          elReadFork.innerHTML = `fork${f.readForkAs ? ' ' + f.readForkAs : ''} reads k = <b ${bfScope}>${f.readFork}</b>`;
        }
        elNote.textContent = f.note;
        elCount.textContent = `${bi} / ${BF.length - 1}`;
        btnPrev.disabled = bi === 0;
        btnNext.disabled = bi === BF.length - 1;
      };

      const goBf = (n: number) => { bi = Math.max(0, Math.min(BF.length - 1, n)); renderBf(); };
      const stopBfPlay = () => {
        if (bfTimer) { clearInterval(bfTimer); bfTimer = null; }
        btnPlay.textContent = 'play';
      };
      btnNext.addEventListener('click', () => { stopBfPlay(); goBf(bi + 1); });
      btnPrev.addEventListener('click', () => { stopBfPlay(); goBf(bi - 1); });
      btnReset.addEventListener('click', () => { stopBfPlay(); goBf(0); });
      btnPlay.addEventListener('click', () => {
        if (bfTimer) { stopBfPlay(); return; }
        if (bi === BF.length - 1) goBf(0);
        btnPlay.textContent = 'pause';
        bfTimer = setInterval(() => {
          if (bi >= BF.length - 1) { stopBfPlay(); return; }
          goBf(bi + 1);
        }, 1400);
      });

      renderBf();
    }
  </script>
</PitchLayout>
