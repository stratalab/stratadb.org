---
// The landing page, v2 (Doc 04). Sections arrive by build phase:
// Phase 2: hero · Phase 3: branching, primitives, time travel · Phase 4: the rest.
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/sections/Hero.astro';
import Branching from '../components/sections/Branching.astro';
import StrataColumn from '../components/sections/StrataColumn.astro';
import TimeTravel from '../components/sections/TimeTravel.astro';
import Inference from '../components/sections/Inference.astro';
import Resources from '../components/sections/Resources.astro';
import InstallClose from '../components/sections/InstallClose.astro';
import release from '../data/release.json';
---

<BaseLayout>
  <Hero />
  <Branching />
  <StrataColumn />
  <TimeTravel />
  <Inference />
  {/* temporarily hidden, will restore soon: */}
  {/* <Resources /> */}
  {/* <InstallClose /> */}
  <script
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'SoftwareApplication',
      name: 'StrataDB',
      description:
        'An embedded database with the whole git model: zero-copy O(1) branches, diff, merge, cherry-pick, time travel, and search — across five primitives. One file, no server.',
      applicationCategory: 'DeveloperApplication',
      operatingSystem: 'macOS, Linux, Windows',
      license: 'https://www.apache.org/licenses/LICENSE-2.0',
      softwareVersion: release.version,
      url: 'https://stratadb.org',
    })}
  />
</BaseLayout>
