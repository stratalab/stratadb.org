---
// Docs routes (Phase 5). `/docs` itself is the designed landing at
// pages/docs/index.astro; the content index.md stays in the collection as the
// machine mirror (/docs/index.md + llms-full) but does not render HTML here.
import { getCollection } from 'astro:content';
import DocsLayout from '../../layouts/DocsLayout.astro';

export async function getStaticPaths() {
  const docs = await getCollection('docs');
  return docs
    .filter((entry) => entry.slug !== 'index')
    .map((entry) => ({
      params: { slug: entry.slug },
      props: { entry },
    }));
}

const { entry } = Astro.props;
const { Content, headings } = await entry.render();
const mdHref = `/docs/${entry.slug}.md`;
---

<DocsLayout
  title={entry.data.title}
  description={entry.data.description}
  mdHref={mdHref}
  headings={headings}
>
  <Content />
</DocsLayout>
